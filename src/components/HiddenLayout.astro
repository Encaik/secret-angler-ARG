---
// HiddenLayout — 隐藏/触发页面专用布局
// 架空佛教宗派"归源宗"内部法务系统——表面是寺院管理后台
// 暖色调寺庙风格，无导航栏，无页脚
// 所有隐藏页面添加 noindex,nofollow
export interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const BASE = __BASE_PATH__;
import '../styles/global.css';
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex,nofollow" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <script define:vars={{ basePath: BASE }}>
    window.__BASE__ = basePath;
  </script>
</head>
<body class="hidden-page">
  <main style="width: 100%; max-width: var(--max-width); margin: 0 auto; padding: 24px 16px; min-height: 100vh;">
    <slot />
  </main>

  <script src="../scripts/console.ts"></script>
  <script src="../scripts/progress.ts"></script>
  <script src="../scripts/search.ts"></script>
  <script>
    const BASE = window.__BASE__ || '/';
    // 记录页面访问
    const progress = JSON.parse(localStorage.getItem('arg_progress') || '{}');
    if (!progress.discoveredClues) progress.discoveredClues = [];
    const pagePath = window.location.pathname.replace(BASE.replace(/\/$/, ''), '').replace(/^\//, '');
    const clueKey = `visited_${pagePath.replace(/\//g, '_')}`;
    if (!progress.discoveredClues.includes(clueKey)) {
      progress.discoveredClues.push(clueKey);
      progress.explorationProgress = Math.min(100, (progress.explorationProgress || 0) + 3);
      localStorage.setItem('arg_progress', JSON.stringify(progress));
    }
  </script>
</body>
</html>

<style>
  /* HiddenLayout — 隐藏页面通用暖色调主题 */
  .hidden-page {
    background: #faf6ee;
    color: #4a3728;
    min-height: 100vh;
  }
  .hidden-page a {
    color: #8b6914;
  }
  .hidden-page a:hover {
    color: #a0782c;
  }
  .hidden-page h1, .hidden-page h2, .hidden-page h3, .hidden-page h4 {
    color: #2c1810;
  }
  .hidden-page .card {
    background: #fefcf7;
    border-color: #e0d5c0;
    color: #4a3728;
  }
  .hidden-page p {
    color: #4a3728;
  }
  .hidden-page .text-muted {
    color: #9b8c7a;
  }
  .hidden-page hr {
    border-color: #e0d5c0;
  }
  .hidden-page .breadcrumb {
    border-bottom-color: #e0d5c0;
    color: #9b8c7a;
  }
  .hidden-page .breadcrumb a {
    color: #8b6914;
  }
  .hidden-page .breadcrumb a:hover {
    color: #a0782c;
  }
  .hidden-page input, .hidden-page textarea {
    background: #fdfaf4;
    border-color: #d5c8b0;
    color: #4a3728;
  }
  .hidden-page code {
    background: #f5eedf;
    color: #8b6914;
    border: 1px solid #e0d5c0;
  }
  .hidden-page pre {
    background: #f5eedf;
    color: #4a3728;
    border: 1px solid #e0d5c0;
  }
  .hidden-page blockquote {
    background: #fdfaf4;
    border-left-color: #c0b090;
    color: #6b5d4a;
  }
  .hidden-page .tag {
    opacity: 0.85;
  }
  .hidden-page .post-item {
    border-bottom-color: #e0d5c0;
  }
  .hidden-page .post-item .post-meta {
    color: #9b8c7a;
  }
  .hidden-page table th {
    background: #f5eedf;
    color: #2c1810;
    border-bottom: 2px solid #d5c8b0;
  }
  .hidden-page table td {
    border-color: #e0d5c0;
    color: #4a3728;
  }
  .hidden-page strong {
    color: #2c1810;
  }

  /* 隐藏页面特有元素——寺庙风格 */
  .hidden-badge {
    display: inline-block;
    background: #8b6914;
    color: #fefcf7;
    font-size: 0.7rem;
    padding: 2px 8px;
    border-radius: 2px;
    letter-spacing: 0.5px;
  }
  .hidden-badge.amber {
    background: #a0782c;
  }
  .hidden-badge.maroon {
    background: #5c2e2e;
  }
  .hidden-badge.teal {
    background: #3d6b6b;
  }
  .hidden-badge.muted {
    background: #9b8c7a;
  }
  .hidden-warning {
    background: #fdf6ed;
    border: 1px solid #d5c8b0;
    color: #6b4a2a;
    padding: 10px 14px;
    border-radius: 2px;
    font-size: 0.82rem;
    margin: 12px 0;
  }
  .hidden-notice {
    background: #f4f6f8;
    border: 1px solid #c0c8d0;
    color: #4a5a6a;
    padding: 10px 14px;
    border-radius: 2px;
    font-size: 0.82rem;
    margin: 12px 0;
  }

  /* 寺庙风格装饰元素 */
  .temple-header {
    text-align: center;
    padding: 16px 0;
    border-bottom: 1px solid #e0d5c0;
    margin-bottom: 20px;
  }
  .temple-header .sect-name {
    font-size: 1.1rem;
    color: #2c1810;
    letter-spacing: 2px;
    font-weight: bold;
  }
  .temple-header .sect-subtitle {
    font-size: 0.72rem;
    color: #9b8c7a;
    margin-top: 2px;
  }
  .temple-divider {
    text-align: center;
    color: #c0b090;
    font-size: 0.8rem;
    padding: 8px 0;
    letter-spacing: 2px;
  }
  .incense-block {
    background: #fefcf7;
    border: 1px solid #e0d5c0;
    padding: 12px 16px;
    margin: 12px 0;
    font-size: 0.82rem;
    color: #6b5d4a;
    line-height: 1.8;
  }
  .incense-block .verse {
    text-align: center;
    color: #8b6914;
    letter-spacing: 1px;
  }
</style>
