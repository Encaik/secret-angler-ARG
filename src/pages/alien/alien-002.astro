import Layout from '../../components/Layout.astro';
const BASE = __BASE_PATH__;
---

<Layout title="全国外星目击高发区坐标数据集">
  <div class="breadcrumb">
    <a href={`${BASE}home/`} target="_blank">首页</a><span>›</span><a href={`${BASE}alien/`} target="_blank">外星目击</a
    ><span>›</span>全国目击坐标数据集
  </div>
  <article>
    <h1>全国外星目击高发区坐标数据集（47点·2025-2026年度）</h1>
    <div class="post-meta">
      作者：<a href={`${BASE}user/lyu/`} target="_blank">signal_屿</a> · 发布于 2026-04-12 · 阅读 532 · 收藏 91
    </div>
    <hr />
    <p>
      整理了近两年收集的<strong>47个高信度外星目击点</strong
      >的精确坐标。数据来源包括：国内外UFO报告数据库、国内爱好者社区的第一手报告、以及本人实地验证的5个点位。
    </p>
    <p>
      使用GIS工具对全部47个点进行了空间分析，制作了<strong>热力分布图</strong
      >。结果很有意思：最密集的三个聚集区恰好落在<strong>北纬30-45度带</strong
      >——这个纬度带也是已知冷门古遗址最密集的区域。凤凰山（44.52, 127.83）、神农架（31.58, 110.42）、昆仑山（36.12,
      94.55）等点位同时出现在两个数据集中。
    </p>
    <p>下表列出了部分已验证的点位坐标和信号特征：</p>

    <table style="font-size: 0.82rem; width: 100%; margin: 12px 0;">
      <tr><th>点位名称</th><th>坐标</th><th>信号频段</th><th>验证状态</th></tr>
      <tr><td>凤凰山</td><td><code>44.52, 127.83</code></td><td>1420MHz</td><td>已验证（signal_屿）</td></tr>
      <tr><td>神农架</td><td><code>31.58, 110.42</code></td><td>未公开</td><td>未验证</td></tr>
      <tr><td>昆仑山</td><td><code>36.12, 94.55</code></td><td>未公开</td><td>未验证</td></tr>
      <tr><td>罗布泊</td><td><code>40.39, 90.22</code></td><td>未公开</td><td>未验证</td></tr>
      <tr
        ><td>贺兰山</td><td><code>38.78, 106.03</code></td><td>2380MHz</td><td
          ><a href={`${BASE}user/shenci/`} target="_blank">@地下三尺</a> 已实地探访</td
        ></tr
      >
      <tr><td>秦岭</td><td><code>33.25, 107.15</code></td><td>未公开</td><td>已验证（signal_屿 + 地下三尺）</td></tr>
      <tr><td>塔克拉玛干</td><td><code>40.15, 83.67</code></td><td>未公开</td><td>未验证——沙漠腹地，需越野车</td></tr>
    </table>

    <p style="margin-top: 12px;">完整47点坐标列表和热力图分析已整理完毕。如有需要可私信索取原始数据。</p>
    <p style="color: #888; font-size: 0.85rem;">
      <em
        >注：近期发现部分点位的信号特征与<strong>民用SDR设备</strong
        >产生的调制信号高度相似——写目击报告的人可能根本不懂无线电。建议读者在前往这些点位前，交叉比对<a
          href={`${BASE}ruins/`}
          target="_blank">古迹板块</a
        >中<a href={`${BASE}user/shenci/`} target="_blank">@地下三尺</a>的坐标合集。你会发现一个有趣的规律。</em
      >
    </p>

    <div class="post-meta" style="margin-top:16px;">
      标签：<span class="tag tag-alien">外星目击</span>
      <span class="tag tag-alien">坐标数据</span>
      <span class="tag tag-alien">信号分析</span>
    </div>
  </article>
</Layout>
