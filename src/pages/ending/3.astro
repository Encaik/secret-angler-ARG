---
// 结局3：局部破获（良结局）— 捣毁基地但头目潜逃
const BASE = __BASE_PATH__;
---

<!doctype html>
<html lang="zh-CN">
  <head
    ><meta charset="UTF-8" /><meta name="viewport" content="width=device-width,initial-scale=1.0" /><meta
      name="robots"
      content="noindex,nofollow"
    /><title>结局 — 秘境垂钓者</title>
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        background: #0a0a0a;
        color: #888;
        font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        line-height: 2;
      }
      .ending {
        max-width: 520px;
        padding: 40px 24px;
        text-align: center;
      }
      .ending h2 {
        color: #2e8b57;
        font-size: 1.3rem;
        margin-bottom: 24px;
        font-weight: 400;
        letter-spacing: 2px;
      }
      .ending p {
        margin-bottom: 14px;
        font-size: 0.9rem;
      }
      .ending .divider {
        color: #333;
        margin: 24px 0;
        letter-spacing: 8px;
      }
      .ending .final {
        color: #555;
        font-size: 0.78rem;
        margin-top: 20px;
      }
      a {
        color: #555;
        font-size: 0.78rem;
      }
    </style></head
  >
  <body>
    <div class="ending">
      <h2>局 部 破 获</h2>
      <p>
        你将暗网交易记录、基地坐标和部分医疗外包线索整理成完整档案，匿名提交给了省公安厅。深海猎手预设的自动举报脚本也在同一周触发了第二次发送。
      </p>
      <p>
        警方当晚成立专案组，次日凌晨突袭了鄂西废弃萤石矿。现场抓获基层人员十二人。四名受害者——包括沈辞——全部获救。沈辞被抬出来的时候，体检记录显示他的HLA配型报告刚出来不到十二个小时。再晚一天，他就会出现在暗网市场的挂牌列表上。
      </p>
      <p>
        但专案组冲进暗网交易控制室的时候，服务器已经被远程擦除。首座和监院在行动开始前一小时收到预警，通过矿道深处的备用出口逃脱。三天后，缅甸方面截获了他们的入境记录。
      </p>
      <p>一个月后，一个新的探秘导航站在暗网上线。不同的域名，相同的模板。</p>
      <div class="divider">···</div>
      <p class="final">链条断了——但蛇头逃了。<br />只要有买家，新的市场就会出现。</p>
      <p class="final" style="margin-top:24px;"><a href={`${BASE}home/`}>重新开始</a></p>
    </div>
  </body>
</html>
