<script>
  const BASE = window.__BASE__ || '/';

  const ADMIN_PASSWORD = 'deeprift323';
  const STAFF_PASSWORD = 'portal2026';
  const ADMIN_USERS = ['admin', '首座', '监院'];
  const STAFF_USERS = ['staff'];

  function doLogin() {
    const user = document.getElementById('admin-user').value.trim();
    const pass = document.getElementById('admin-pass').value.trim();
    const errorEl = document.getElementById('admin-login-error');

    if (!user || !pass) {
      errorEl.textContent = '请输入账号和密码。';
      errorEl.style.display = 'block';
      return;
    }

    // Staff 登录
    if (STAFF_USERS.includes(user.toLowerCase()) && pass === STAFF_PASSWORD) {
      document.getElementById('admin-login').style.display = 'none';
      document.getElementById('staff-panel').style.display = 'block';
      document.getElementById('staff-op-name').textContent = user;

      const progress = JSON.parse(localStorage.getItem('arg_progress') || '{}');
      if (!progress.solvedPuzzles) progress.solvedPuzzles = {};
      progress.solvedPuzzles['stage_staff_access'] = true;
      if (!progress.discoveredClues) progress.discoveredClues = [];
      if (!progress.discoveredClues.includes('staff_access')) {
        progress.discoveredClues.push('staff_access');
      }
      progress.explorationProgress = Math.min(100, (progress.explorationProgress || 0) + 5);
      localStorage.setItem('arg_progress', JSON.stringify(progress));

      errorEl.style.display = 'none';
      return;
    }

    // Admin 登录
    if (ADMIN_USERS.includes(user) && pass === ADMIN_PASSWORD) {
      document.getElementById('admin-login').style.display = 'none';
      document.getElementById('admin-panel').style.display = 'block';
      document.getElementById('admin-op-name').textContent = user;

      const progress = JSON.parse(localStorage.getItem('arg_progress') || '{}');
      if (!progress.solvedPuzzles) progress.solvedPuzzles = {};
      progress.solvedPuzzles['stage3_hidden_admin_password'] = true;
      if (!progress.discoveredClues) progress.discoveredClues = [];
      if (!progress.discoveredClues.includes('admin_access')) {
        progress.discoveredClues.push('admin_access');
      }
      progress.explorationProgress = Math.min(100, (progress.explorationProgress || 0) + 8);
      localStorage.setItem('arg_progress', JSON.stringify(progress));

      errorEl.style.display = 'none';
      return;
    }

    errorEl.textContent = '账号或密码错误，请重试。';
    errorEl.style.display = 'block';
  }

  document.getElementById('admin-login-btn').addEventListener('click', doLogin);

  document.getElementById('admin-pass').addEventListener('keydown', (e) => {
    if (e.key === 'Enter') doLogin();
  });

  // 退出按钮
  document.getElementById('staff-logout-btn')?.addEventListener('click', () => {
    document.getElementById('admin-login').style.display = 'block';
    document.getElementById('staff-panel').style.display = 'none';
    document.getElementById('admin-pass').value = '';
  });

  document.getElementById('admin-logout-btn')?.addEventListener('click', () => {
    document.getElementById('admin-login').style.display = 'block';
    document.getElementById('admin-panel').style.display = 'none';
    document.getElementById('admin-pass').value = '';
  });
</script>
