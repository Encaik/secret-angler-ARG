---
// /hidden/admin — 团伙后台管理系统入口
// 模拟团伙内部管理面板。需输入管理密码。
// 密码线索来自 trigger 页面中的内部通讯记录
import HiddenLayout from '../../components/HiddenLayout.astro';
const BASE = __BASE_PATH__;
---

<HiddenLayout title="后台管理系统">
  <!-- 登录界面 -->
  <div id="admin-login" style="max-width: 420px; margin: 60px auto;">
    <div style="text-align: center; margin-bottom: 24px;">
      <h2 style="color: #c0392b; margin-bottom: 4px;">⛔ 后台管理系统</h2>
      <p class="text-muted">内部使用 · 未经授权访问将被记录</p>
    </div>

    <div class="card">
      <div style="margin-bottom: 14px;">
        <label style="display: block; font-size: 0.82rem; color: #888; margin-bottom: 4px;">操作员ID</label>
        <input type="text" id="admin-user" placeholder="输入操作员ID" style="max-width: 100%;" value="admin" />
      </div>
      <div style="margin-bottom: 14px;">
        <label style="display: block; font-size: 0.82rem; color: #888; margin-bottom: 4px;">认证密钥</label>
        <input type="password" id="admin-pass" placeholder="输入认证密钥" style="max-width: 100%;" />
      </div>
      <button id="admin-login-btn" style="width: 100%; padding: 10px; background: #c0392b; color: #fff; border: none; cursor: pointer; font-size: 0.9rem;">
        验证身份
      </button>
      <p id="admin-login-error" style="color: #c0392b; font-size: 0.78rem; margin-top: 8px; display: none; text-align: center;"></p>
    </div>

    <p class="text-muted" style="text-align: center; font-size: 0.72rem; margin-top: 16px;">
      如遗忘认证密钥，请联系系统管理员重置。<br />
      密钥格式：项目代号+安全后缀
    </p>
  </div>

  <!-- 管理面板（登录后显示） -->
  <div id="admin-panel" style="display: none;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
      <div>
        <h2 style="color: #c0392b; margin-bottom: 2px;">⛔ 后台管理系统</h2>
        <p class="text-muted" style="font-size: 0.78rem;">已认证 · 操作员：<strong id="admin-op-name" style="color: #e0dcd5;"></strong> · 最后登录：2026-06-03 22:47</p>
      </div>
      <button id="admin-logout-btn" style="padding: 6px 14px; background: #333; color: #888; border: 1px solid #444; cursor: pointer; font-size: 0.78rem;">
        退出
      </button>
    </div>

    <div class="hidden-warning">
      ⚠ 系统通知：上级指示——"深海裂隙"项目捕获目标"三尺"后，本站进入<strong>三个月冷却期</strong>。期间禁止新诱捕行动。对 signal_屿 的监控持续进行，如发现其有实地探查行为立即上报。
    </div>

    <!-- 功能模块列表 -->
    <div class="two-col" style="margin-top: 16px;">
      <!-- 左栏 -->
      <div>
        <div class="card" style="border-left: 3px solid #c0392b;">
          <h4 style="margin-bottom: 8px;">📋 内部通讯板</h4>
          <p style="font-size: 0.82rem; color: #888; margin-bottom: 8px;">团伙成员加密通讯。最近更新：2026-06-03。</p>
          <a href={`${BASE}hidden/board/`} target="_blank" style="font-size: 0.82rem;">进入通讯板 →</a>
        </div>

        <div class="card" style="border-left: 3px solid #c0392b;">
          <h4 style="margin-bottom: 8px;">📁 作案流程手册</h4>
          <p style="font-size: 0.82rem; color: #888; margin-bottom: 8px;">标准作案全流程文档。从筛选目标到清理痕迹。</p>
          <a href={`${BASE}hidden/operation/`} target="_blank" style="font-size: 0.82rem;">查看手册 →</a>
        </div>

        <div class="card" style="border-left: 3px solid #c0392b;">
          <h4 style="margin-bottom: 8px;">🗺️ 全国基地坐标</h4>
          <p style="font-size: 0.82rem; color: #888; margin-bottom: 8px;">各伏击点位与主基地的精确坐标 + 设施模块分布 + 库存状态。</p>
          <a href={`${BASE}hidden/locations/`} target="_blank" style="font-size: 0.82rem;">查看坐标 →</a>
        </div>
      </div>

      <!-- 右栏 -->
      <div>
        <div class="card" style="border-left: 3px solid #c0392b;">
          <h4 style="margin-bottom: 8px;">👤 目标档案</h4>
          <p style="font-size: 0.82rem; color: #888; margin-bottom: 8px;">所有已筛选目标的详细档案与评估报告。</p>
          <a href={`${BASE}hidden/targets/`} target="_blank" style="font-size: 0.82rem;">查看档案 →</a>
        </div>

        <div class="card" style="border-left: 3px solid #c0392b;">
          <h4 style="margin-bottom: 8px;">⚠️ 叛变成员信息</h4>
          <p style="font-size: 0.82rem; color: #888; margin-bottom: 8px;">一名前成员试图向警方举报。已处理。残留信息存档。</p>
          <a href={`${BASE}hidden/dead-drop/`} target="_blank" style="font-size: 0.82rem;">查看信息 →</a>
        </div>

        <div class="card" style="border-left: 3px solid #c0392b;">
          <h4 style="margin-bottom: 8px;">🔒 证据缓存</h4>
          <p style="font-size: 0.82rem; color: #888; margin-bottom: 8px;">用于反侦察的证据销毁缓存区。定时清理。</p>
          <a href={`${BASE}hidden/evidence-locker/`} target="_blank" style="font-size: 0.82rem;">查看缓存 →</a>
        </div>

        <div class="card" style="border-left: 3px solid #4a8c6a;">
          <h4 style="margin-bottom: 8px;">🕵️ 暗网交易市场</h4>
          <p style="font-size: 0.82rem; color: #888; margin-bottom: 8px;">外部入口——暗网商品交易平台（器官/人口）。</p>
          <a href={`${BASE}hidden/darknet/`} target="_blank" style="font-size: 0.82rem; color: #4a8c6a;">进入市场 →</a>
        </div>
      </div>
    </div>

    <!-- 最近操作日志 -->
    <div class="card" style="margin-top: 16px;">
      <h4 style="margin-bottom: 8px;">📜 最近操作日志</h4>
      <table style="font-size: 0.78rem;">
        <tr><th>时间</th><th>操作员</th><th>操作</th><th>详情</th></tr>
        <tr>
          <td>2026-06-03 18:22</td>
          <td>运营_A</td>
          <td>内容删除</td>
          <td style="font-size:0.72rem;">删除贺兰山相关推荐帖3篇。理由：点位任务已完成。</td>
        </tr>
        <tr>
          <td>2026-06-02 14:10</td>
          <td>技术_B</td>
          <td>账号监控</td>
          <td style="font-size:0.72rem;">标记 signal_屿 为"重点观察"。未检测到实地探查迹象。</td>
        </tr>
        <tr>
          <td>2026-06-01 09:45</td>
          <td>运营_A</td>
          <td>舆论引导</td>
          <td style="font-size:0.72rem;">通过"山野探秘人"账号发布正常路线分享帖，稀释质疑帖的搜索权重。</td>
        </tr>
        <tr>
          <td>2026-05-29 23:15</td>
          <td>技术_B</td>
          <td>数据清理</td>
          <td style="font-size:0.72rem;">清理会员区部分缓存数据（未完成——三尺的帖文权限过高，需直接操作数据库）。</td>
        </tr>
        <tr>
          <td>2026-05-26 08:30</td>
          <td>运营_A</td>
          <td>任务确认</td>
          <td style="font-size:0.72rem;">贺兰山点位任务完成。目标"三尺"已入库#SKU-2026-003。体检分类中——HLA分型待外部实验室确认（预计6月8日）。</td>
        </tr>
      </table>
    </div>
  </div>
</HiddenLayout>

<script>
  const BASE = window.__BASE__ || '/';

  // 管理密码：线索来自 trigger/rift 页面中的内部域名 "deeprift323.onion"
  const ADMIN_PASSWORD = 'deeprift323';
  const ADMIN_USERS = ['admin', '运营_A', '技术_B'];

  document.getElementById('admin-login-btn')!.addEventListener('click', () => {
    const user = (document.getElementById('admin-user') as HTMLInputElement).value.trim();
    const pass = (document.getElementById('admin-pass') as HTMLInputElement).value.trim();
    const errorEl = document.getElementById('admin-login-error')!;

    if (!user || !pass) {
      errorEl.textContent = '请输入操作员ID和认证密钥。';
      errorEl.style.display = 'block';
      return;
    }

    if (ADMIN_USERS.includes(user) && pass === ADMIN_PASSWORD) {
      // 登录成功
      document.getElementById('admin-login')!.style.display = 'none';
      document.getElementById('admin-panel')!.style.display = 'block';
      document.getElementById('admin-op-name')!.textContent = user;

      // 记录进度
      const progress = JSON.parse(localStorage.getItem('arg_progress') || '{}');
      if (!progress.solvedPuzzles) progress.solvedPuzzles = {};
      progress.solvedPuzzles['stage3_hidden_admin_password'] = true;
      if (!progress.discoveredClues) progress.discoveredClues = [];
      if (!progress.discoveredClues.includes('admin_access')) {
        progress.discoveredClues.push('admin_access');
      }
      progress.explorationProgress = Math.min(100, (progress.explorationProgress || 0) + 8);
      localStorage.setItem('arg_progress', JSON.stringify(progress));

      errorEl.style.display = 'none';
    } else {
      errorEl.textContent = '认证失败：操作员ID或密钥不正确。';
      errorEl.style.display = 'block';
    }
  });

  // 回车键提交
  document.getElementById('admin-pass')!.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      document.getElementById('admin-login-btn')!.click();
    }
  });

  // 退出
  document.getElementById('admin-logout-btn')!.addEventListener('click', () => {
    document.getElementById('admin-login')!.style.display = 'block';
    document.getElementById('admin-panel')!.style.display = 'none';
    (document.getElementById('admin-pass') as HTMLInputElement).value = '';
  });
</script>
