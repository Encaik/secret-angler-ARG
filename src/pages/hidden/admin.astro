---
// /hidden/admin — 寺院管理系统（团伙后台）
// staff 视图：客堂运营面板（有限权限）
// admin 视图：方丈管理面板（全部权限）
import HiddenLayout from '../../components/HiddenLayout.astro';
const BASE = __BASE_PATH__;
---

<HiddenLayout title="寺院管理系统">
  <!-- 登录界面 -->
  <div id="admin-login" style="max-width: 400px; margin: 80px auto;">
    <div class="temple-header">
      <div class="sect-name">归 源 宗</div>
      <div class="sect-subtitle">寺院管理系统</div>
    </div>
    <div class="card" style="background: #fefcf7; border: 1px solid #e0d5c0;">
      <div style="margin-bottom: 12px;">
        <label style="display: block; font-size: 0.78rem; color: #6b5d4a; margin-bottom: 4px;">账号</label>
        <input type="text" id="admin-user" placeholder="" value="" style="width:100%;max-width:100%;padding:7px 10px;background:#fdfaf4;border:1px solid #d5c8b0;color:#4a3728;font-size:0.85rem;" />
      </div>
      <div style="margin-bottom: 14px;">
        <label style="display: block; font-size: 0.78rem; color: #6b5d4a; margin-bottom: 4px;">密码</label>
        <input type="password" id="admin-pass" placeholder="" style="width:100%;max-width:100%;padding:7px 10px;background:#fdfaf4;border:1px solid #d5c8b0;color:#4a3728;font-size:0.85rem;" />
      </div>
      <button id="admin-login-btn" style="width:100%;padding:8px;background:#8b6914;color:#fefcf7;border:1px solid #7a5a10;cursor:pointer;font-size:0.85rem;">
        登录
      </button>
      <p id="admin-login-error" style="color:#8b3a3a;font-size:0.72rem;margin-top:6px;display:none;text-align:center;"></p>
    </div>
    <p style="text-align:center;font-size:0.68rem;color:#b0a090;margin-top:12px;">
      归源宗内部系统 · 仅限授权人员
    </p>
  </div>

  <!-- ========== STAFF 视图：客堂运营面板 ========== -->
  <div id="staff-panel" style="display: none;">

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid #e0d5c0;">
      <div style="display:flex;align-items:center;gap:16px;">
        <span style="font-size:0.9rem;color:#2c1810;font-weight:bold;">寺院管理系统 · 客堂视图</span>
        <span style="font-size:0.72rem;color:#9b8c7a;">当前用户：<strong id="staff-op-name" style="color:#4a3728;"></strong></span>
      </div>
      <div style="display:flex;gap:8px;">
        <span style="font-size:0.68rem;color:#b0a090;">完整管理功能需方丈授权</span>
        <button id="staff-logout-btn" style="padding:4px 12px;background:none;color:#9b8c7a;border:1px solid #e0d5c0;cursor:pointer;font-size:0.72rem;">退出</button>
      </div>
    </div>

    <!-- 导航（受限） -->
    <div style="display:flex;gap:0;margin-bottom:16px;border-bottom:2px solid #e0d5c0;flex-wrap:wrap;">
      <span style="padding:6px 14px;font-size:0.78rem;color:#8b6914;border-bottom:2px solid #8b6914;">总览</span>
      <span style="padding:6px 14px;font-size:0.78rem;color:#c0b090;cursor:not-allowed;" title="权限不足 - 需方丈授权">内部通讯</span>
      <a href={`${BASE}hidden/operation/`} target="_blank" style="padding:6px 14px;font-size:0.78rem;color:#6b5d4a;text-decoration:none;">操作手册</a>
      <span style="padding:6px 14px;font-size:0.78rem;color:#c0b090;cursor:not-allowed;" title="权限不足 - 需方丈授权">据点坐标</span>
      <span style="padding:6px 14px;font-size:0.78rem;color:#c0b090;cursor:not-allowed;" title="权限不足 - 需方丈授权">目标档案</span>
      <span style="padding:6px 14px;font-size:0.78rem;color:#c0b090;cursor:not-allowed;" title="权限不足 - 需方丈授权">人员处置</span>
      <span style="padding:6px 14px;font-size:0.78rem;color:#c0b090;cursor:not-allowed;" title="权限不足 - 需方丈授权">证据管理</span>
      <span style="margin-left:auto;padding:6px 14px;font-size:0.72rem;color:#3d6b6b;">景区香火：<a href={`${BASE}hidden/panlongxia/`} target="_blank" style="color:#3d6b6b;">盘龙峡香火站</a></span>
    </div>

    <!-- 统计卡片（仅基础数据） -->
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:16px;">
      <div style="background:#fefcf7;border:1px solid #e0d5c0;padding:12px;">
        <div style="font-size:0.65rem;color:#9b8c7a;">本月法会场次</div>
        <div style="font-size:1.2rem;color:#2c1810;">3</div>
        <div style="font-size:0.6rem;color:#b0a090;">春季 · 夏季 · 秋季（筹备中）</div>
      </div>
      <div style="background:#fefcf7;border:1px solid #e0d5c0;padding:12px;">
        <div style="font-size:0.65rem;color:#9b8c7a;">在寺信众</div>
        <div style="font-size:1.2rem;color:#2c1810;">5</div>
        <div style="font-size:0.6rem;color:#b0a090;">3 闭关 · 1 示现 · 1 待评估</div>
      </div>
      <div style="background:#fefcf7;border:1px solid #e0d5c0;padding:12px;">
        <div style="font-size:0.65rem;color:#9b8c7a;">本月供养收入</div>
        <div style="font-size:1.2rem;color:#2c1810;">$412K</div>
        <div style="font-size:0.6rem;color:#b0a090;">功德流通 + 法会直播</div>
      </div>
    </div>

    <!-- 法会日程管理 -->
    <div style="margin-bottom:16px;">
      <div style="font-size:0.78rem;color:#6b5d4a;margin-bottom:6px;">法会日程管理</div>
      <table style="font-size:0.72rem;width:100%;">
        <tr style="color:#6b5d4a;"><th style="text-align:left;padding:4px 8px;">法会</th><th style="text-align:left;padding:4px 8px;">日期</th><th style="text-align:left;padding:4px 8px;">地点</th><th style="text-align:left;padding:4px 8px;">状态</th></tr>
        <tr style="color:#4a3728;">
          <td style="padding:3px 8px;">春季归源法会</td><td style="padding:3px 8px;">04-15 至 04-20</td>
          <td style="padding:3px 8px;">贺兰山净修禅院</td><td style="padding:3px 8px;color:#3d6b6b;">已圆满</td>
        </tr>
        <tr style="color:#4a3728;">
          <td style="padding:3px 8px;">夏季归源法会</td><td style="padding:3px 8px;">05-25 至 05-28</td>
          <td style="padding:3px 8px;">凤凰山</td><td style="padding:3px 8px;color:#3d6b6b;">已圆满</td>
        </tr>
        <tr style="color:#4a3728;">
          <td style="padding:3px 8px;">秋季归源法会</td><td style="padding:3px 8px;">09-01 起</td>
          <td style="padding:3px 8px;">待公告</td><td style="padding:3px 8px;color:#a0702c;">筹备中</td>
        </tr>
      </table>
    </div>

    <!-- 信众名录（部分列） -->
    <div style="margin-bottom:16px;">
      <div style="font-size:0.78rem;color:#6b5d4a;margin-bottom:6px;">信众名录</div>
      <table style="font-size:0.72rem;width:100%;">
        <tr style="color:#6b5d4a;"><th style="text-align:left;padding:4px 8px;">法号</th><th style="text-align:left;padding:4px 8px;">入院日期</th><th style="text-align:left;padding:4px 8px;">状态</th><th style="text-align:left;padding:4px 8px;">备注</th></tr>
        <tr style="color:#4a3728;">
          <td style="padding:3px 8px;">旅人</td><td style="padding:3px 8px;">2026-03-15</td><td style="padding:3px 8px;color:#3d6b6b;">已离寺</td><td style="padding:3px 8px;font-size:0.65rem;">金身渡化·西域</td>
        </tr>
        <tr style="color:#4a3728;">
          <td style="padding:3px 8px;">观星者</td><td style="padding:3px 8px;">2026-04-02</td><td style="padding:3px 8px;color:#3d6b6b;">已离寺</td><td style="padding:3px 8px;font-size:0.65rem;">分身渡化·南洋</td>
        </tr>
        <tr style="color:#4a3728;">
          <td style="padding:3px 8px;">三尺</td><td style="padding:3px 8px;">2026-05-26</td><td style="padding:3px 8px;color:#8b6914;">闭关中</td><td style="padding:3px 8px;font-size:0.65rem;">需冷链·配型中</td>
        </tr>
        <tr style="color:#4a3728;">
          <td style="padding:3px 8px;">登山客</td><td style="padding:3px 8px;">2026-05-30</td><td style="padding:3px 8px;color:#5a7a3a;">示现中</td><td style="padding:3px 8px;font-size:0.65rem;">法台甲</td>
        </tr>
        <tr style="color:#4a3728;">
          <td style="padding:3px 8px;">背包客</td><td style="padding:3px 8px;">2026-05-30</td><td style="padding:3px 8px;color:#8b6914;">闭关中</td><td style="padding:3px 8px;font-size:0.65rem;">待评估</td>
        </tr>
      </table>
      <p style="font-size:0.65rem;color:#c0b090;margin-top:4px;">※ 完整档案（含俗名、来源地、评估数据）需方丈权限。</p>
    </div>

    <!-- 供养记录 -->
    <div style="margin-bottom:16px;">
      <div style="font-size:0.78rem;color:#6b5d4a;margin-bottom:6px;">本月供养记录（部分）</div>
      <table style="font-size:0.72rem;width:100%;">
        <tr style="color:#6b5d4a;"><th style="text-align:left;padding:4px 8px;">日期</th><th style="text-align:left;padding:4px 8px;">施主</th><th style="text-align:left;padding:4px 8px;">项目</th><th style="text-align:right;padding:4px 8px;">功德金</th></tr>
        <tr style="color:#4a3728;">
          <td style="padding:3px 8px;">05-20</td><td style="padding:3px 8px;">陈居士</td><td style="padding:3px 8px;">金刚舍利 + 甘露</td><td style="padding:3px 8px;text-align:right;">135,000</td>
        </tr>
        <tr style="color:#4a3728;">
          <td style="padding:3px 8px;">04-15</td><td style="padding:3px 8px;">王居士</td><td style="padding:3px 8px;">金身渡化</td><td style="padding:3px 8px;text-align:right;">48,000</td>
        </tr>
        <tr style="color:#4a3728;">
          <td style="padding:3px 8px;">03-08</td><td style="padding:3px 8px;">——</td><td style="padding:3px 8px;">甘露</td><td style="padding:3px 8px;text-align:right;">82,000</td>
        </tr>
      </table>
      <p style="font-size:0.65rem;color:#c0b090;margin-top:4px;">※ 完整功德簿含施主详情与去向，需方丈权限。</p>
    </div>

    <!-- 操作日志（仅内容相关） -->
    <div style="margin-bottom:16px;">
      <div style="font-size:0.78rem;color:#6b5d4a;margin-bottom:6px;">操作日志</div>
      <table style="font-size:0.72rem;width:100%;">
        <tr style="color:#6b5d4a;"><th style="text-align:left;padding:4px 8px;">时间</th><th style="text-align:left;padding:4px 8px;">操作人</th><th style="text-align:left;padding:4px 8px;">内容</th></tr>
        <tr style="color:#4a3728;">
          <td style="padding:3px 8px;">06-03 17:00</td><td style="padding:3px 8px;">首座</td>
          <td style="padding:3px 8px;font-size:0.68rem;">删除贺兰山相关引导帖×3。甲辰003已收押。</td>
        </tr>
        <tr style="color:#4a3728;">
          <td style="padding:3px 8px;">06-01 09:00</td><td style="padding:3px 8px;">首座</td>
          <td style="padding:3px 8px;font-size:0.68rem;">外联人员发布常规帖文×2，维持站点活跃度。</td>
        </tr>
        <tr style="color:#4a3728;">
          <td style="padding:3px 8px;">05-29 23:00</td><td style="padding:3px 8px;">监院</td>
          <td style="padding:3px 8px;font-size:0.68rem;">清理缓存数据——部分失败。甲辰003文件权限过高。</td>
        </tr>
      </table>
    </div>

    <!-- 提示横幅 -->
    <div style="background:#fdf6ed;border:1px solid #e0d0a0;padding:8px 14px;font-size:0.72rem;color:#6b4a2a;">
      ⚠ 当前为客堂视图。完整管理功能（内部通讯、档案管理、坐标数据、人员处置记录、证据管理）需以方丈身份登录。
    </div>
  </div>

  <!-- ========== ADMIN 视图：方丈管理面板（当前完整面板） ========== -->
  <div id="admin-panel" style="display: none;">

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid #e0d5c0;">
      <div style="display:flex;align-items:center;gap:16px;">
        <span style="font-size:0.9rem;color:#2c1810;font-weight:bold;">归源宗 · 管理后台</span>
        <span style="font-size:0.72rem;color:#9b8c7a;">当前用户：<strong id="admin-op-name" style="color:#4a3728;"></strong></span>
        <span style="font-size:0.68rem;color:#b0a090;">上次登录：2026-06-03 21:00</span>
      </div>
      <div style="display:flex;gap:8px;">
        <span style="font-size:0.68rem;color:#8b6914;padding:2px 8px;background:#faf3e0;border:1px solid #e0d0a0;border-radius:2px;">冷却期 · 距下次行动：87天</span>
        <button id="admin-logout-btn" style="padding:4px 12px;background:none;color:#9b8c7a;border:1px solid #e0d5c0;cursor:pointer;font-size:0.72rem;">退出</button>
      </div>
    </div>

    <!-- 导航标签（完整） -->
    <div style="display:flex;gap:0;margin-bottom:16px;border-bottom:2px solid #e0d5c0;">
      <a href={`${BASE}hidden/admin/`} target="_blank" style="padding:6px 14px;font-size:0.78rem;color:#8b6914;border-bottom:2px solid #8b6914;text-decoration:none;">总览</a>
      <a href={`${BASE}hidden/board/`} target="_blank" style="padding:6px 14px;font-size:0.78rem;color:#6b5d4a;text-decoration:none;">内部通讯</a>
      <a href={`${BASE}hidden/operation/`} target="_blank" style="padding:6px 14px;font-size:0.78rem;color:#6b5d4a;text-decoration:none;">操作手册</a>
      <a href={`${BASE}hidden/locations/`} target="_blank" style="padding:6px 14px;font-size:0.78rem;color:#6b5d4a;text-decoration:none;">据点坐标</a>
      <a href={`${BASE}hidden/targets/`} target="_blank" style="padding:6px 14px;font-size:0.78rem;color:#6b5d4a;text-decoration:none;">目标档案</a>
      <a href={`${BASE}hidden/dead-drop/`} target="_blank" style="padding:6px 14px;font-size:0.78rem;color:#6b5d4a;text-decoration:none;">人员处置</a>
      <a href={`${BASE}hidden/evidence-locker/`} target="_blank" style="padding:6px 14px;font-size:0.78rem;color:#6b5d4a;text-decoration:none;">证据管理</a>
      <span style="margin-left:auto;padding:6px 14px;font-size:0.72rem;color:#3d6b6b;">香火市场：<a href={`${BASE}hidden/panlongxia/`} target="_blank" style="color:#3d6b6b;">盘龙峡</a></span>
    </div>

    <!-- 待办警示 -->
    <div style="background:#fdf6ed;border:1px solid #e0d0a0;padding:8px 14px;margin-bottom:16px;font-size:0.72rem;color:#6b4a2a;">
      ⚠ 待处理：管理员密码逾期未更换 · 甲辰003档案权限未清理 · 证据删除队列待确认（排程：06-06 00:00）· <strong style="color:#5c2e2e;">退转弟子深观·自动举报脚本第5轮重发——拦截失败。</strong>
    </div>

    <!-- 统计卡片 -->
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:12px;margin-bottom:16px;">
      <div style="background:#fefcf7;border:1px solid #e0d5c0;padding:12px;">
        <div style="font-size:0.65rem;color:#9b8c7a;">活跃站点</div>
        <div style="font-size:1.2rem;color:#2c1810;">3</div>
        <div style="font-size:0.6rem;color:#b0a090;">论坛 · 信号网络 · 中央基地</div>
      </div>
      <div style="background:#fefcf7;border:1px solid #e0d5c0;padding:12px;">
        <div style="font-size:0.65rem;color:#9b8c7a;">在押人员</div>
        <div style="font-size:1.2rem;color:#2c1810;">5</div>
        <div style="font-size:0.6rem;color:#b0a090;">3 待处理 · 1 展示中 · 1 待评估</div>
      </div>
      <div style="background:#fefcf7;border:1px solid #e0d5c0;padding:12px;">
        <div style="font-size:0.65rem;color:#9b8c7a;">本月收入</div>
        <div style="font-size:1.2rem;color:#2c1810;">$412K</div>
        <div style="font-size:0.6rem;color:#b0a090;">暗网市场 + 直播频道</div>
      </div>
      <div style="background:#fefcf7;border:1px solid #e0d5c0;padding:12px;">
        <div style="font-size:0.65rem;color:#9b8c7a;">监控目标</div>
        <div style="font-size:1.2rem;color:#5c2e2e;">2</div>
        <div style="font-size:0.6rem;color:#b0a090;">signal_屿（重点）· 废弃中（普通）</div>
      </div>
    </div>

    <!-- 操作日志（完整） -->
    <div style="margin-bottom:16px;">
      <div style="font-size:0.78rem;color:#6b5d4a;margin-bottom:6px;">操作日志</div>
      <table style="font-size:0.72rem;width:100%;">
        <tr style="color:#6b5d4a;"><th style="text-align:left;padding:4px 8px;">时间</th><th style="text-align:left;padding:4px 8px;">操作人</th><th style="text-align:left;padding:4px 8px;">模块</th><th style="text-align:left;padding:4px 8px;">内容</th></tr>
        <tr style="color:#4a3728;">
          <td style="padding:3px 8px;">06-03 17:00</td><td style="padding:3px 8px;">首座</td><td style="padding:3px 8px;">内容管理</td>
          <td style="padding:3px 8px;font-size:0.68rem;">删除贺兰山相关引导帖×3。甲辰003（沈辞）已收押。</td>
        </tr>
        <tr style="color:#4a3728;">
          <td style="padding:3px 8px;">06-03 23:00</td><td style="padding:3px 8px;">首座</td><td style="padding:3px 8px;">证据管理</td>
          <td style="padding:3px 8px;font-size:0.68rem;">批量标记待删除数据。操作中断——部分文件权限不足。</td>
        </tr>
        <tr style="color:#4a3728;">
          <td style="padding:3px 8px;">06-02 13:00</td><td style="padding:3px 8px;">监院</td><td style="padding:3px 8px;">目标监控</td>
          <td style="padding:3px 8px;font-size:0.68rem;">signal_屿（林屿）升级为"重点监控"。暂无实地调查迹象。</td>
        </tr>
        <tr style="color:#4a3728;">
          <td style="padding:3px 8px;">06-01 09:00</td><td style="padding:3px 8px;">首座</td><td style="padding:3px 8px;">外联</td>
          <td style="padding:3px 8px;font-size:0.68rem;">外联人员发布常规帖文×2，维持站点活跃度。</td>
        </tr>
        <tr style="color:#4a3728;">
          <td style="padding:3px 8px;">05-29 23:00</td><td style="padding:3px 8px;">监院</td><td style="padding:3px 8px;">内容管理</td>
          <td style="padding:3px 8px;font-size:0.68rem;">清理在押人员区缓存数据——部分失败。甲辰003（沈辞）文件权限过高。</td>
        </tr>
        <tr style="color:#4a3728;">
          <td style="padding:3px 8px;">05-26 07:00</td><td style="padding:3px 8px;">首座</td><td style="padding:3px 8px;">目标管理</td>
          <td style="padding:3px 8px;font-size:0.68rem;">新增目标 甲辰003·三尺（沈辞）。体检评估待外院医生确认。</td>
        </tr>
      </table>
    </div>

    <!-- 快捷入口 -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:0.72rem;">
      <div style="background:#fefcf7;border:1px solid #e0d5c0;padding:8px 12px;">
        <span style="color:#9b8c7a;">在押人员</span>
        <span style="float:right;color:#4a3728;">4 人 · <a href={`${BASE}hidden/panlongxia/`} target="_blank" style="color:#3d6b6b;">查看香火</a></span>
      </div>
      <div style="background:#fefcf7;border:1px solid #e0d5c0;padding:8px 12px;">
        <span style="color:#9b8c7a;">安全警报</span>
        <span style="float:right;color:#5c2e2e;">1 项未处理 · <a href={`${BASE}hidden/dead-drop/`} target="_blank" style="color:#5c2e2e;">查看</a></span>
      </div>
      <div style="background:#fefcf7;border:1px solid #e0d5c0;padding:8px 12px;">
