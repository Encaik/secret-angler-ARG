---
// /hidden/darknet — 暗网交易市场
// 通过"加入我们"弹窗中的链接进入
import HiddenLayout from '../../components/HiddenLayout.astro';
const BASE = __BASE_PATH__;
---

<HiddenLayout title="秘境">
  <div style="max-width: 960px; margin: 0 auto;">

    <!-- 顶部——极简标识 -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid #1a2a1a;">
      <div>
        <span style="font-size: 1.1rem; font-weight: bold; color: #4a7c5a; letter-spacing: 1px;">THE SANCTUM</span>
        <span style="font-size: 0.7rem; color: #3a5a3a; margin-left: 8px;">v2.4.1</span>
      </div>
      <div style="font-size: 0.72rem; color: #555;">
        <span id="header-balance" style="color: #4a7c5a;">--</span> ·
        <span id="header-user" style="color: #666;">未登录</span>
      </div>
    </div>

    <!-- 登录区域 -->
    <div id="login-section">
      <div style="max-width: 360px; margin: 60px auto;">
        <div style="text-align: center; margin-bottom: 20px;">
          <span style="font-size: 2rem;">🔻</span>
        </div>
        <div style="background: #0d0d0d; border: 1px solid #222; border-radius: 4px; padding: 24px;">
          <div style="margin-bottom: 14px;">
            <label style="font-size: 0.75rem; color: #555; display: block; margin-bottom: 4px;">账号</label>
            <input type="text" id="darknet-username" placeholder="" style="width: 100%; max-width: 100%; padding: 8px 10px; background: #0a0a0a; border: 1px solid #2a2a2a; color: #aaa; font-size: 0.88rem;" />
          </div>
          <div style="margin-bottom: 16px;">
            <label style="font-size: 0.75rem; color: #555; display: block; margin-bottom: 4px;">密码</label>
            <input type="password" id="darknet-password" placeholder="" style="width: 100%; max-width: 100%; padding: 8px 10px; background: #0a0a0a; border: 1px solid #2a2a2a; color: #aaa; font-size: 0.88rem;" />
          </div>
          <button id="darknet-login-btn" style="width: 100%; padding: 9px; background: #1a2a1a; color: #5a8a5a; border: 1px solid #2a3a2a; cursor: pointer; font-size: 0.85rem;">登录</button>
          <p id="login-error" style="color: #8b3a3a; font-size: 0.72rem; margin-top: 8px; display: none;"></p>
        </div>
        <p style="text-align: center; color: #444; font-size: 0.68rem; margin-top: 10px;">
          没有凭证？通过推荐人获取邀请码。
        </p>
      </div>
    </div>

    <!-- 登录后内容 -->
    <div id="darknet-content" style="display: none;">

      <!-- 导航标签 -->
      <div style="display: flex; gap: 0; margin-bottom: 20px; border-bottom: 1px solid #1a2a1a;">
        <span class="nav-tab active" data-tab="market" style="padding: 8px 16px; font-size: 0.8rem; color: #4a7c5a; border-bottom: 2px solid #4a7c5a; cursor: pointer;">市场</span>
        <span class="nav-tab" data-tab="live" style="padding: 8px 16px; font-size: 0.8rem; color: #555; cursor: pointer;">直播</span>
        <span class="nav-tab" data-tab="history" style="padding: 8px 16px; font-size: 0.8rem; color: #555; cursor: pointer;">成交记录</span>
        <span class="nav-tab" data-tab="wallet" style="padding: 8px 16px; font-size: 0.8rem; color: #555; cursor: pointer;">钱包</span>
      </div>

      <!-- ============ 市场标签页 ============ -->
      <div id="tab-market">

        <!-- 筛选栏 -->
        <div style="display: flex; gap: 12px; margin-bottom: 16px; font-size: 0.78rem; color: #666;">
          <span style="color: #4a7c5a;">全部</span>
          <span style="cursor: pointer;">器官</span>
          <span style="cursor: pointer;">整人</span>
          <span style="cursor: pointer;">待评估</span>
          <span style="margin-left: auto; font-size: 0.72rem;">共 4 件商品</span>
        </div>

        <!-- 商品卡片：沈辞 -->
        <div style="background: #0d0d0d; border: 1px solid #1a1a1a; border-radius: 4px; padding: 16px; margin-bottom: 12px;">
          <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px;">
            <div>
              <span style="color: #aaa; font-size: 0.9rem; font-weight: bold;">#SKU-2026-003</span>
              <span style="color: #4a7c5a; font-size: 0.75rem; margin-left: 6px;">三尺</span>
              <span style="background: #1a1a1a; color: #8b7a3a; font-size: 0.65rem; padding: 1px 6px; border-radius: 2px; margin-left: 6px;">评估中</span>
            </div>
            <span style="color: #555; font-size: 0.7rem;">入库 05-26</span>
          </div>
          <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; font-size: 0.78rem; margin-bottom: 8px;">
            <div><span style="color: #555;">年龄/性别</span><br/><span style="color: #999;">20 / 男</span></div>
            <div><span style="color: #555;">血型</span><br/><span style="color: #999;">O</span></div>
            <div><span style="color: #555;">HLA</span><br/><span style="color: #8b7a3a;">检测中</span></div>
            <div><span style="color: #555;">健康</span><br/><span style="color: #8b7a3a;">评估中</span></div>
            <div><span style="color: #555;">等级</span><br/><span style="color: #999;">A-</span></div>
            <div><span style="color: #555;">估价</span><br/><span style="color: #555;">待发布</span></div>
          </div>
          <div style="font-size: 0.72rem; color: #555; padding: 6px 8px; background: #0a0a0a; border-radius: 2px;">
            适用：肾脏（双） · 肝脏（部分） · 角膜 · 整人
            &nbsp;|&nbsp; 直播：频道B「古文明探秘」
          </div>
        </div>

        <!-- 商品卡片：已售 -->
        <div style="background: #0d0d0d; border: 1px solid #1a1a1a; border-radius: 4px; padding: 14px; margin-bottom: 10px; opacity: 0.7;">
          <span style="color: #777; font-size: 0.85rem;">#SKU-2026-001</span>
          <span style="color: #666; font-size: 0.72rem; margin-left: 6px;">旅人</span>
          <span style="background: #1a2a1a; color: #4a7c5a; font-size: 0.65rem; padding: 1px 6px; border-radius: 2px; margin-left: 6px;">已售</span>
          <span style="color: #555; font-size: 0.72rem; float: right;">整人 · $48,000</span>
        </div>

        <div style="background: #0d0d0d; border: 1px solid #1a1a1a; border-radius: 4px; padding: 14px; margin-bottom: 10px; opacity: 0.7;">
          <span style="color: #777; font-size: 0.85rem;">#SKU-2026-002</span>
          <span style="color: #666; font-size: 0.72rem; margin-left: 6px;">观星者</span>
          <span style="background: #1a1a1a; color: #8b5a3a; font-size: 0.65rem; padding: 1px 6px; border-radius: 2px; margin-left: 6px;">已拆解</span>
          <span style="color: #555; font-size: 0.72rem; float: right;">肾脏×1 · 角膜×2 · $135,000</span>
        </div>

        <div style="background: #0d0d0d; border: 1px solid #1a1a1a; border-radius: 4px; padding: 14px; margin-bottom: 10px;">
          <span style="color: #aaa; font-size: 0.85rem;">#SKU-2026-004</span>
          <span style="color: #666; font-size: 0.72rem; margin-left: 6px;">行者</span>
          <span style="background: #1a1a1a; color: #6a8a3a; font-size: 0.65rem; padding: 1px 6px; border-radius: 2px; margin-left: 6px;">展示中</span>
          <span style="color: #555; font-size: 0.72rem; float: right;">频道A「外星秘境」</span>
        </div>
      </div>

      <!-- ============ 直播标签页 ============ -->
      <div id="tab-live" style="display: none;">
        <div style="font-size: 0.82rem; color: #888; margin-bottom: 16px;">当前在线频道</div>
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px;">
          <div style="background: #0d0d0d; border: 1px solid #1a1a1a; border-radius: 4px; padding: 14px;">
            <div style="color: #aaa; font-size: 0.85rem; margin-bottom: 6px;">外星秘境</div>
            <div style="font-size: 0.72rem; color: #555;">频道A · 340订阅</div>
            <div style="font-size: 0.72rem; color: #4a7c5a; margin-top: 4px;">● 在线</div>
            <div style="font-size: 0.68rem; color: #555; margin-top: 6px;">月费 $29 · 行者</div>
          </div>
          <div style="background: #0d0d0d; border: 1px solid #1a1a1a; border-radius: 4px; padding: 14px;">
            <div style="color: #aaa; font-size: 0.85rem; margin-bottom: 6px;">古文明探秘</div>
            <div style="font-size: 0.72rem; color: #555;">频道B · 280订阅</div>
            <div style="font-size: 0.72rem; color: #4a7c5a; margin-top: 4px;">● 在线</div>
            <div style="font-size: 0.68rem; color: #555; margin-top: 6px;">月费 $29 · 三尺</div>
          </div>
          <div style="background: #0d0d0d; border: 1px solid #1a1a1a; border-radius: 4px; padding: 14px;">
            <div style="color: #666; font-size: 0.85rem; margin-bottom: 6px;">荒野求生</div>
            <div style="font-size: 0.72rem; color: #555;">频道C · 210订阅</div>
            <div style="font-size: 0.72rem; color: #555; margin-top: 4px;">○ 离线</div>
            <div style="font-size: 0.68rem; color: #555; margin-top: 6px;">月费 $19</div>
          </div>
        </div>
        <div style="font-size: 0.7rem; color: #444; margin-top: 12px;">
          每场直播叠加实时体征数据（心率、血氧、步数）。频道A/B支持高阶数据分析（$39/月附加包）。
        </div>
      </div>

      <!-- ============ 成交记录标签页 ============ -->
      <div id="tab-history" style="display: none;">
        <table style="font-size: 0.78rem; width: 100%;">
          <tr style="color: #555;"><th style="text-align: left; padding: 6px 8px;">日期</th><th style="text-align: left;">商品</th><th style="text-align: left;">来源</th><th style="text-align: right;">成交价</th><th style="text-align: right;">买家地区</th></tr>
          <tr style="color: #888;"><td style="padding: 6px 8px;">2026-05-20</td><td>肾脏×1 + 角膜×2</td><td>观星者</td><td style="text-align: right;">$135,000</td><td style="text-align: right;">东南亚</td></tr>
          <tr style="color: #888;"><td style="padding: 6px 8px;">2026-04-15</td><td>整人</td><td>旅人</td><td style="text-align: right;">$48,000</td><td style="text-align: right;">中东</td></tr>
          <tr style="color: #666;"><td style="padding: 6px 8px;">2026-03-08</td><td>肝脏（部分）</td><td>—</td><td style="text-align: right;">$82,000</td><td style="text-align: right;">东欧</td></tr>
          <tr style="color: #666;"><td style="padding: 6px 8px;">2026-02-21</td><td>整人</td><td>—</td><td style="text-align: right;">$35,000</td><td style="text-align: right;">南美</td></tr>
          <tr style="color: #666;"><td style="padding: 6px 8px;">2026-01-14</td><td>肾脏×1</td><td>—</td><td style="text-align: right;">$58,000</td><td style="text-align: right;">中东</td></tr>
        </table>
        <div style="font-size: 0.7rem; color: #444; margin-top: 10px;">仅展示最近6个月记录。完整历史数据需升级至企业账户。</div>
      </div>

      <!-- ============ 钱包标签页 ============ -->
      <div id="tab-wallet" style="display: none;">
        <div style="background: #0d0d0d; border: 1px solid #1a1a1a; border-radius: 4px; padding: 16px; max-width: 400px;">
          <div style="font-size: 0.8rem; color: #555; margin-bottom: 4px;">账户余额</div>
          <div style="font-size: 1.4rem; color: #4a7c5a; margin-bottom: 12px;">$0.00</div>
          <div style="font-size: 0.72rem; color: #555; margin-bottom: 4px;">充值地址（BTC）</div>
          <code style="font-size: 0.68rem; color: #666; background: #0a0a0a; padding: 4px 8px; display: block; word-break: break-all;">bc1qly0w63v0s0dujf0ly5kz5v0cw0kq0d5s0x0r0y</code>
          <div style="font-size: 0.72rem; color: #555; margin-top: 10px; margin-bottom: 4px;">充值地址（XMR）</div>
          <code style="font-size: 0.68rem; color: #666; background: #0a0a0a; padding: 4px 8px; display: block; word-break: break-all;">48x0v0d0u0j0f0l0y0k0z0v0c0w0k0q0d0s0x0r0y0a0b0c0d0e0f0123456789ab</code>
        </div>
      </div>

    </div>
  </div>
</HiddenLayout>

<style>
  .nav-tab:hover { color: #888; }
</style>

<script>
  const BASE = (window as any).__BASE__ || '/';

  const VALID_ACCOUNTS: Record<string, string> = {
    'DR-2026-03': 'rift0603',
  };

  function doLogin() {
    const username = (document.getElementById('darknet-username') as HTMLInputElement).value.trim();
    const password = (document.getElementById('darknet-password') as HTMLInputElement).value;
    const errorEl = document.getElementById('login-error');
    const loginSection = document.getElementById('login-section');
    const content = document.getElementById('darknet-content');
    const headerUser = document.getElementById('header-user');
    const headerBalance = document.getElementById('header-balance');

    if (VALID_ACCOUNTS[username] && VALID_ACCOUNTS[username] === password) {
      if (errorEl) errorEl.style.display = 'none';
      if (loginSection) loginSection.style.display = 'none';
      if (content) content.style.display = 'block';
      if (headerUser) headerUser.textContent = username;
      if (headerBalance) headerBalance.textContent = '$0.00';

      const stored = localStorage.getItem('arg_progress');
      if (stored) {
        const p = JSON.parse(stored);
        if (!p.solvedPuzzles) p.solvedPuzzles = {};
        p.solvedPuzzles['stage4_darknet_access'] = true;
        if (!p.discoveredClues) p.discoveredClues = [];
        if (!p.discoveredClues.includes('darknet_marketplace')) {
          p.discoveredClues.push('darknet_marketplace');
          p.explorationProgress = (p.explorationProgress || 0) + 20;
        }
        if (!p.discoveredPages) p.discoveredPages = [];
        if (!p.discoveredPages.includes('/hidden/darknet')) {
          p.discoveredPages.push('/hidden/darknet');
        }
        localStorage.setItem('arg_progress', JSON.stringify(p));
      }
    } else {
      if (errorEl) {
        errorEl.textContent = '账号或密码错误。';
        errorEl.style.display = 'block';
      }
    }
  }

  function tryAutoFill() {
    const stored = localStorage.getItem('arg_progress');
    if (stored) {
      const p = JSON.parse(stored);
      if (p.darknetAccount) {
        const u = document.getElementById('darknet-username') as HTMLInputElement;
        const pw = document.getElementById('darknet-password') as HTMLInputElement;
        if (u) u.value = p.darknetAccount.account || '';
        if (pw) pw.value = p.darknetAccount.password || '';
      }
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    tryAutoFill();

    document.getElementById('darknet-login-btn')?.addEventListener('click', doLogin);
    document.getElementById('darknet-password')?.addEventListener('keydown', (e) => { if (e.key === 'Enter') doLogin(); });
    document.getElementById('darknet-username')?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') (document.getElementById('darknet-password') as HTMLInputElement)?.focus();
    });

    // 标签切换
    document.querySelectorAll('.nav-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const tabName = (tab as HTMLElement).dataset.tab;
        document.querySelectorAll('.nav-tab').forEach(t => {
          (t as HTMLElement).style.color = '#555';
          (t as HTMLElement).style.borderBottom = 'none';
        });
        (tab as HTMLElement).style.color = '#4a7c5a';
        (tab as HTMLElement).style.borderBottom = '2px solid #4a7c5a';
        ['market','live','history','wallet'].forEach(id => {
          const el = document.getElementById('tab-' + id);
          if (el) el.style.display = id === tabName ? 'block' : 'none';
        });
      });
    });
  });
</script>
