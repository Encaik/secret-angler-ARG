---
// /hidden/darknet — 暗网交易市场（内部站）
// 通过搜索"深度探秘"（公告中的暗网会员关键词）触发
// 需要暗网专属账号登录——账号从"加入我们"页面获得
import HiddenLayout from '../../../components/HiddenLayout.astro';
const BASE = __BASE_PATH__;
---

<HiddenLayout title="秘境 · 深度探秘">
  <!-- 无面包屑——切断与钓鱼站的视觉关联 -->
  <!-- 使用 HiddenLayout 暗色主题 + 绿色强调色（区别于后台页的红色） -->

  <div style="text-align: center; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid #1a3a2a;">
    <div style="font-size: 1.4rem; font-weight: bold; color: #4a8c6a; letter-spacing: 2px; margin-bottom: 4px;">
      🔻 秘境 · 深度探秘
    </div>
    <div style="font-size: 0.72rem; color: #3a5a4a; letter-spacing: 1px;">
      THE SANCTUM · DEEP EXPLORATION
    </div>
    <div style="font-size: 0.68rem; color: #555; margin-top: 4px;">
      永无止境 · 安全第一
    </div>
  </div>

  <!-- 登录区域 -->
  <div id="login-section">
    <div class="card" style="border-left: 3px solid #4a8c6a; max-width: 380px; margin: 0 auto;">
      <p style="color: #7aac8a; font-size: 0.85rem; margin-bottom: 12px;">
        <strong>🔐 会员登录</strong>
      </p>
      <p style="color: #888; font-size: 0.78rem; margin-bottom: 16px;">
        请输入您的<strong>专属访问凭证</strong>。如尚未获得账号，请通过"加入我们"页面申请。
      </p>

      <div style="margin-bottom: 10px;">
        <label style="font-size: 0.78rem; color: #666; display: block; margin-bottom: 3px;">账号</label>
        <input
          type="text"
          id="darknet-username"
          placeholder="输入账号"
          style="width: 100%; max-width: 100%; padding: 8px 12px; background: #0a0f0a; border: 1px solid #333; color: #aaa; font-size: 0.9rem;"
        />
      </div>

      <div style="margin-bottom: 14px;">
        <label style="font-size: 0.78rem; color: #666; display: block; margin-bottom: 3px;">密码</label>
        <input
          type="password"
          id="darknet-password"
          placeholder="输入密码"
          style="width: 100%; max-width: 100%; padding: 8px 12px; background: #0a0f0a; border: 1px solid #333; color: #aaa; font-size: 0.9rem;"
        />
      </div>

      <button
        id="darknet-login-btn"
        style="width: 100%; padding: 10px; background: #1a3a2a; color: #7aac8a; border: 1px solid #2a5a3a; cursor: pointer; font-size: 0.92rem;"
      >登录</button>
      <p id="login-error" style="color: #c0392b; font-size: 0.78rem; margin-top: 8px; display: none;"></p>
    </div>

    <!-- 登录提示 -->
    <p style="text-align: center; color: #555; font-size: 0.72rem; margin-top: 12px;">
      没有账号？访问<a href={`${BASE}about/`} target="_blank" style="color: #4a8c6a;">加入我们</a>页面获取专属凭证。
    </p>
  </div>

  <!-- ============ 登录后内容（初始隐藏） ============ -->
  <div id="darknet-content" style="display: none;">

    <!-- 已登录状态条 -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; padding: 8px 12px; background: #0d1a0d; border-radius: 3px; font-size: 0.78rem;">
      <span style="color: #4a8c6a;">🟢 已登录 · <strong id="logged-user">---</strong> · 深度探秘会员</span>
      <a href="javascript:void(0)" id="logout-btn" style="color: #888; font-size: 0.75rem;">退出</a>
    </div>

    <!-- 导航栏——内部站功能导航 -->
    <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 24px; padding: 10px 0; border-bottom: 1px solid #1a3a2a;">
      <span style="color: #4a8c6a; font-size: 0.82rem; cursor: pointer; padding: 4px 10px; background: #0d1a0d; border-radius: 3px;">📊 在售商品</span>
      <span style="color: #666; font-size: 0.82rem; padding: 4px 10px;">📺 直播频道</span>
      <span style="color: #666; font-size: 0.82rem; padding: 4px 10px;">🫁 器官交易</span>
      <span style="color: #666; font-size: 0.82rem; padding: 4px 10px;">👤 人口贩卖</span>
      <span style="color: #666; font-size: 0.82rem; padding: 4px 10px;">📋 交易记录</span>
      <span style="color: #666; font-size: 0.82rem; padding: 4px 10px;">💬 买家讨论</span>
    </div>

    <!-- 警告横幅 -->
    <div class="hidden-warning" style="margin-bottom: 20px; font-size: 0.82rem;">
      <strong>⚠ 你正在浏览的是一个真实的暗网交易平台。</strong><br/>
      以下内容涉及<strong>器官贩卖、人口贩卖</strong>等严重犯罪行为。页面中的"商品"均为被绑架的真实受害者。
      请保存所有可获取的证据，并立即报告执法部门。
    </div>

    <!-- "在售商品"列表 -->
    <div style="margin-bottom: 20px;">
      <h3 style="color: #aaa; font-size: 0.95rem; margin-bottom: 12px; border-bottom: 1px solid #222; padding-bottom: 6px;">
        📊 当前在售商品
      </h3>

      <!-- 沈辞 -->
      <div class="card" style="border-left: 3px solid #c0392b; margin-bottom: 12px; background: #0d0d0d;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
          <div style="flex: 1;">
            <strong style="color: #c0392b; font-size: 0.95rem;">#SKU-2026-003 · 代号"三尺"</strong>
            <span style="color: #e67e22; font-size: 0.72rem; margin-left: 8px;">状态：体检评估中</span>
          </div>
          <span style="color: #888; font-size: 0.72rem;">入库：2026-05-26</span>
        </div>
        <table style="font-size: 0.78rem; margin-top: 8px;">
          <tr><td style="width: 25%; color: #666;">年龄/性别</td><td>22岁 / 男</td></tr>
          <tr><td style="color: #666;">血型</td><td>O型（已确认）</td></tr>
          <tr><td style="color: #666;">HLA分型</td><td><span style="color: #888;">检测中——预计6月8日完成</span></td></tr>
          <tr><td style="color: #666;">健康评分</td><td><span style="color: #e67e22;">待发布——体能评估进行中</span></td></tr>
          <tr><td style="color: #666;">商品等级</td><td><span style="color: #f39c12;">A-（年轻健康，无已知疾病，O型血适配面广）</span></td></tr>
          <tr><td style="color: #666;">适用方向</td><td>肾脏（双肾健康）· 肝脏部分 · 角膜 · 整人交易</td></tr>
          <tr><td style="color: #666;">当前出价</td><td><span style="color: #888;">暂无——等待健康评估报告发布</span></td></tr>
        </table>
        <div style="margin-top: 8px; padding: 6px 10px; background: #0a0f0a; border-radius: 3px; font-size: 0.75rem; color: #666;">
          <strong>📺 直播预览：</strong>可在频道B「古文明探秘」观看该商品的日常活动。直播叠加实时健康数据。
        </div>
      </div>

      <!-- 其他商品 -->
      <div class="card" style="border-left: 3px solid #555; margin-bottom: 12px; background: #0d0d0d;">
        <strong style="color: #aaa; font-size: 0.9rem;">#SKU-2026-001 · 代号"旅人"</strong>
        <span style="color: #27ae60; font-size: 0.72rem; margin-left: 8px;">已售出</span>
        <span style="color: #888; font-size: 0.72rem; float: right;">成交价：$48,000（整人交易）</span>
      </div>

      <div class="card" style="border-left: 3px solid #555; margin-bottom: 12px; background: #0d0d0d;">
        <strong style="color: #aaa; font-size: 0.9rem;">#SKU-2026-002 · 代号"观星者"</strong>
        <span style="color: #c0392b; font-size: 0.72rem; margin-left: 8px;">器官已摘取</span>
        <span style="color: #888; font-size: 0.72rem; float: right;">肾脏×1 + 角膜×2 · 合计$135,000</span>
      </div>

      <div class="card" style="border-left: 3px solid #555; margin-bottom: 12px; background: #0d0d0d;">
        <strong style="color: #aaa; font-size: 0.9rem;">#SKU-2026-004 · 代号"行者"</strong>
        <span style="color: #e67e22; font-size: 0.72rem; margin-left: 8px;">直播展示中</span>
        <span style="color: #888; font-size: 0.72rem; float: right;">频道A「外星秘境」· 买家评估中</span>
      </div>
    </div>

    <!-- 器官交易区 -->
    <div style="margin-bottom: 20px;">
      <h3 style="color: #aaa; font-size: 0.95rem; margin-bottom: 12px; border-bottom: 1px solid #222; padding-bottom: 6px;">
        🫁 器官交易 · 当前挂牌
      </h3>
      <table style="font-size: 0.78rem;">
        <tr><th style="width: 20%;">器官</th><th style="width: 15%;">血型</th><th>来源代号</th><th style="width: 15%;">状态</th><th style="width: 20%;">估价</th></tr>
        <tr><td>肾脏（左）</td><td>B型</td><td>"观星者"</td><td><span style="color:#27ae60;">已售</span></td><td>$62,000</td></tr>
        <tr><td>角膜（双）</td><td>—</td><td>"观星者"</td><td><span style="color:#27ae60;">已售</span></td><td>$11,000</td></tr>
        <tr><td>肾脏（双）</td><td>O型</td><td>"三尺"</td><td><span style="color:#e67e22;">待评估</span></td><td>待健康报告</td></tr>
        <tr><td>肝脏（部分）</td><td>O型</td><td>"三尺"</td><td><span style="color:#e67e22;">待评估</span></td><td>待健康报告</td></tr>
      </table>
    </div>

    <!-- 买家讨论区 -->
    <div style="margin-bottom: 20px;">
      <h3 style="color: #aaa; font-size: 0.95rem; margin-bottom: 12px; border-bottom: 1px solid #222; padding-bottom: 6px;">
        💬 买家讨论 · 最近留言
      </h3>
      <div style="font-size: 0.8rem; color: #777; line-height: 1.6;">
        <p style="margin-bottom: 6px; padding: 6px 8px; background: #0a0f0a; border-radius: 3px;">
          <strong style="color: #5a8a6a;">User_9a3f</strong> <span style="color: #555;">· 2026-06-02</span><br/>
          "三尺那个O型血确认了吗？我这里有个肾衰竭病人等了三个月了。健康报告出来后私我。"
        </p>
        <p style="margin-bottom: 6px; padding: 6px 8px; background: #0a0f0a; border-radius: 3px;">
          <strong style="color: #5a8a6a;">User_b7d2</strong> <span style="color: #555;">· 2026-06-01</span><br/>
          "这批货质量比上一批好。旅人那个有点可惜——买家是中东那边的，付款拖了很久。观星者的角膜已经装上了，配型完美。"
        </p>
        <p style="margin-bottom: 6px; padding: 6px 8px; background: #0a0f0a; border-radius: 3px;">
          <strong style="color: #5a8a6a;">User_1e8c</strong> <span style="color: #555;">· 2026-05-30</span><br/>
          "频道C那个'行者'耐力不错，我看了两周直播，心率数据一直很稳定。脑子也清楚——语言测试反应快。我在考虑整人下单，有没有其他人竞价？"
        </p>
      </div>
    </div>

    <!-- 关键证据摘要 -->
    <div class="hidden-notice" style="margin-top: 20px;">
      <p style="margin-bottom: 4px;"><strong>💡 已获取的关键证据：</strong></p>
      <ul style="margin-bottom: 0; padding-left: 1.5em; color: #88d; font-size: 0.82rem;">
        <li>沈辞（代号"三尺"）被列为#SKU-2026-003号商品——<strong>HLA分型预计6月8日完成</strong>。在此之前必须采取行动。</li>
        <li>已确认<strong>至少4名受害者</strong>（三尺/旅人/观星者/行者），其中1人已被摘取器官、1人已被整人出售。</li>
        <li>器官交易通过<strong>独立的地下医疗网络</strong>完成——这是追踪链条中最脆弱的环节。</li>
        <li>买家讨论中提及的"中东买家"、"肾衰竭病人"、"角膜配型"等细节可协助警方追踪下游犯罪网络。</li>
        <li><strong>沈辞的O型血确认、健康评估报告预计6月8日前完成</strong>——届时器官交易将正式挂牌。时间窗口正在关闭。</li>
        <li>搜索"<strong>后台管理</strong>"可进入团伙内部管理系统，获取更详细的证据（坐标、通讯记录、叛变成员信息）。</li>
      </ul>
    </div>
  </div>
</HiddenLayout>

<script>
  const BASE = (window as any).__BASE__ || '/';

  // 有效的暗网账号列表
  const VALID_ACCOUNTS: Record<string, string> = {
    'DR-2026-03': 'rift0603',
    // 可扩展更多账号
  };

  function doLogin() {
    const username = (document.getElementById('darknet-username') as HTMLInputElement).value.trim();
    const password = (document.getElementById('darknet-password') as HTMLInputElement).value;
    const errorEl = document.getElementById('login-error');
    const loginSection = document.getElementById('login-section');
    const content = document.getElementById('darknet-content');
    const loggedUser = document.getElementById('logged-user');

    // 验证账号密码
    if (VALID_ACCOUNTS[username] && VALID_ACCOUNTS[username] === password) {
      // 登录成功
      if (errorEl) errorEl.style.display = 'none';
      if (loginSection) loginSection.style.display = 'none';
      if (content) content.style.display = 'block';
      if (loggedUser) loggedUser.textContent = username;

      // 记录进度
      const stored = localStorage.getItem('arg_progress');
      if (stored) {
        const p = JSON.parse(stored);
        if (!p.solvedPuzzles) p.solvedPuzzles = {};
        p.solvedPuzzles['stage4_darknet_access'] = true;
        if (!p.discoveredClues) p.discoveredClues = [];
        if (!p.discoveredClues.includes('darknet_marketplace')) {
          p.discoveredClues.push('darknet_marketplace');
          p.explorationProgress = (p.explorationProgress || 0) + 20;
        }
        localStorage.setItem('arg_progress', JSON.stringify(p));
      }
    } else {
      // 登录失败
      if (errorEl) {
        errorEl.textContent = '⚠ 账号或密码错误。请检查您的访问凭证。如尚未获得账号，请通过"加入我们"页面申请。';
        errorEl.style.display = 'block';
      }
    }
  }

  // 尝试自动填入之前保存的暗网账号
  function tryAutoFill() {
    const stored = localStorage.getItem('arg_progress');
    if (stored) {
      const p = JSON.parse(stored);
      if (p.darknetAccount) {
        const usernameInput = document.getElementById('darknet-username') as HTMLInputElement;
        const passwordInput = document.getElementById('darknet-password') as HTMLInputElement;
        if (usernameInput) usernameInput.value = p.darknetAccount.account || '';
        if (passwordInput) passwordInput.value = p.darknetAccount.password || '';
      }
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    tryAutoFill();

    // 登录按钮
    document.getElementById('darknet-login-btn')?.addEventListener('click', doLogin);

    // 回车登录
    document.getElementById('darknet-password')?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') doLogin();
    });
    document.getElementById('darknet-username')?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        (document.getElementById('darknet-password') as HTMLInputElement)?.focus();
      }
    });

    // 退出登录
    document.getElementById('logout-btn')?.addEventListener('click', () => {
      const loginSection = document.getElementById('login-section');
      const content = document.getElementById('darknet-content');
      if (loginSection) loginSection.style.display = 'block';
      if (content) content.style.display = 'none';
    });
  });
</script>
