        </div>
      </div>

      <!-- ============ 直播频道 ============ -->
      <div id="tab-live" style="display: none;">
        <div style="font-size: 0.82rem; color: #6b5d4a; margin-bottom: 16px;">直播频道 · 实时生理数据</div>
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px;">
          <div style="background: #fefcf7; border: 1px solid #e0d5c0; border-radius: 4px; padding: 14px;">
            <div style="color: #2c1810; font-size: 0.85rem; margin-bottom: 6px;">玄天秘境</div>
            <div style="font-size: 0.72rem; color: #9b8c7a;">频道甲 · 340 订阅</div>
