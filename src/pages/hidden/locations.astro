---
// /hidden/locations — 据点坐标数据库（团伙设施坐标）
import HiddenLayout from '../../components/HiddenLayout.astro';
const BASE = __BASE_PATH__;
---

<HiddenLayout title="据点坐标">
  <div class="breadcrumb">
    <a href={`${BASE}hidden/admin/`} target="_blank">管理后台</a><span>›</span>
    据点坐标
  </div>

  <h2 style="color: #2c1810; margin-bottom: 4px;">据点坐标数据库</h2>
  <p class="text-muted" style="margin-bottom: 16px;">
    密级：内部 · 最后更新：2026-05-30 · 包含全部基地、信号灯阵列、行动伏击点
  </p>

  <div class="hidden-warning">
    ⚠
    以下为全部据点和信号设施坐标。一旦泄露将导致所有活跃站点暴露。前成员郑义（深观）曾试图将此数据外传。访问此页面将生成审计日志。
  </div>

  <!-- 中央基地 -->
  <div class="card" style="margin-bottom: 12px; border-left: 3px solid #8b6914;">
    <h4>中央基地（代号：净修禅院）</h4>
    <p style="font-size:0.78rem;color:#6b5d4a;margin-bottom:8px;">
      六区一体：体检分类区 · 关押区 · 直播区 · 医疗区 · 暗网管理室 · 安保/后勤区
    </p>
    <table style="font-size: 0.8rem;">
      <tr><th>设施名称</th><th>位置</th><th>坐标</th><th>状态</th></tr>
      <tr>
        <td><strong>中央基地</strong></td>
        <td>鄂西某废弃萤石矿深层巷道</td>
        <td><code>31.12, 111.45</code></td>
        <td><span style="color:#3d6b6b;">运行中</span></td>
      </tr>
      <tr>
        <td>备用基地</td>
        <td>川西南某废弃煤矿</td>
        <td><code>29.34, 103.28</code></td>
        <td><span style="color:#a0702c;">维护中</span></td>
      </tr>
    </table>
    <p style="font-size:0.72rem;color:#9b8c7a;margin-top:6px;">
      中央基地当前在押人员：<strong>4人</strong>（编号甲辰001"旅人"已移交 · 甲辰002"观星者"已处理 · 甲辰003"三尺"体检中
      · 甲辰004"行者"展示中）。 医疗排期：待外院医生团队确认（预计下轮手术窗口：六月中旬）。
    </p>
  </div>

  <!-- 信号灯阵列 -->
  <div class="card" style="margin-bottom: 12px; border-left: 3px solid #3d6b6b;">
    <h4>信号灯阵列部署记录（活跃中）</h4>
    <table style="font-size: 0.78rem;">
      <tr><th>编号</th><th>灯位名称</th><th>坐标</th><th>设灯日期</th><th>状态</th></tr>
      <tr>
        <td>DL-001</td><td>凤凰山</td><td><code>44.52, 127.83</code></td><td>2026-03-15</td><td
          ><span style="color:#3d6b6b;">运行中</span></td
        >
      </tr>
      <tr>
        <td>DL-003</td><td>贺兰山</td><td><code>38.78, 106.03</code></td><td>2026-04-20</td><td
          ><span style="color:#5c2e2e;">行动完成</span></td
        >
      </tr>
      <tr>
        <td>DL-007</td><td>昆仑山</td><td><code>36.12, 94.55</code></td><td>2026-05-01</td><td
          ><span style="color:#3d6b6b;">运行中</span></td
        >
      </tr>
      <tr>
        <td>DL-012</td><td>罗布泊</td><td><code>40.39, 90.22</code></td><td>2026-05-10</td><td
          ><span style="color:#3d6b6b;">运行中</span></td
        >
      </tr>
      <tr>
        <td>DL-023</td><td>秦岭</td><td><code>33.25, 107.15</code></td><td>2026-05-15</td><td
          ><span style="color:#a0702c;">信号异常</span></td
        >
      </tr>
    </table>
    <p style="font-size:0.72rem;color:#9b8c7a;margin-top:6px;">共47处。上表仅列关键灯位。完整记录见附件。</p>
  </div>

  <!-- 行动伏击点 -->
  <div class="card" style="margin-bottom: 12px; border-left: 3px solid #8b6914;">
    <h4>行动伏击点（与信号灯位重合）</h4>
    <table style="font-size: 0.78rem;">
      <tr><th>伏击点名</th><th>诱饵类型</th><th>坐标</th><th>对应灯位</th><th>行动状态</th></tr>
      <tr>
        <td>贺兰山未录岩画群</td><td>偏远古迹</td><td><code>38.78, 106.03</code></td><td>DL-003</td><td
          ><span style="color:#5c2e2e;">已完成（沈辞）</span></td
        >
      </tr>
      <tr>
        <td>凤凰山古祭祀遗址</td><td>人工布景</td><td><code>44.52, 127.83</code></td><td>DL-001</td><td
          ><span style="color:#a0702c;">待命</span></td
        >
      </tr>
      <tr style="opacity: 0.55;">
        <td>秦岭"唐代摩崖石刻"</td><td>人工布景</td><td><code>33.25, 107.15</code></td><td>DL-023</td><td
          ><span style="color:#9b8c7a;">已暴露</span></td
        >
      </tr>
      <tr>
        <td>神农架远古石阵</td><td>自然+人工布景</td><td><code>31.58, 110.42</code></td><td>DL-002</td><td
          ><span style="color:#9b8c7a;">暂停</span></td
        >
      </tr>
      <tr>
        <td>哀牢山古滇国祭祀台</td><td>人工布景</td><td><code>24.05, 101.67</code></td><td>—</td><td
          ><span style="color:#a0702c;">待命</span></td
        >
      </tr>
    </table>
  </div>
</HiddenLayout>
