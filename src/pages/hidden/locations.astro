---
// /hidden/locations — 全国基地坐标数据库
// 揭示所有伏击点位与布景基地的位置
import HiddenLayout from '../../components/HiddenLayout.astro';
const BASE = __BASE_PATH__;
---

<HiddenLayout title="全国基地坐标">
  <div class="breadcrumb">
    <a href={`${BASE}hidden/admin/`} target="_blank">后台管理</a><span>›</span>
    全国基地坐标
  </div>

  <h2 style="color: #c0392b; margin-bottom: 4px;">🗺️ 全国基地坐标数据库</h2>
  <p class="text-muted" style="margin-bottom: 16px;">分类：绝密 · 最后更新：2026-05-30 · 包含所有已部署、待部署、已废弃点位</p>

  <div class="hidden-warning">
    ⚠ 此数据库是组织最敏感的资产。一旦泄露，所有活跃点位将立即暴露。前成员"深海猎手"曾试图将此数据外传。访问此页面将触发审计日志。
  </div>

  <!-- 布景基地（主设施——"加工厂"） -->
  <div class="card" style="margin-bottom: 12px; border-left: 3px solid #c0392b;">
    <h4>🏗️ 布景基地（主设施 · 代号"加工厂"）</h4>
    <p style="font-size:0.78rem;color:#888;margin-bottom:8px;">
      六模块一体化设施：体检分类区 · 收容区 · 直播展示区 · 手术区 · 交易控制室 · 警卫/后勤区
    </p>
    <table style="font-size: 0.8rem;">
      <tr><th>设施</th><th>位置</th><th>坐标</th><th>状态</th></tr>
      <tr>
        <td><strong>主基地</strong></td>
        <td>鄂西某废弃萤石矿深层巷道</td>
        <td><code>31.12, 111.45</code></td>
        <td><span style="color:#27ae60;">运行中</span></td>
      </tr>
      <tr>
        <td>备用基地</td>
        <td>川西南某废弃煤矿</td>
        <td><code>29.34, 103.28</code></td>
        <td><span style="color:#e67e22;">维护中</span></td>
      </tr>
    </table>
    <p style="font-size:0.72rem;color:#666;margin-top:6px;">
      主基地当前库存：<strong>4人</strong>（#SKU-001"旅人"已售 · #SKU-002"观星者"器官已摘取 · #SKU-003"三尺"体检评估中 · #SKU-004"行者"直播展示中）。
      手术区排期：待外部医疗团队确认（预计下一轮手术窗口：6月中旬）。
    </p>
  </div>

  <!-- 已部署信号点位 -->
  <div class="card" style="margin-bottom: 12px; border-left: 3px solid var(--color-tag-alien);">
    <h4>📡 信号发射器部署点位（活跃）</h4>
    <table style="font-size: 0.78rem;">
      <tr><th>编号</th><th>点位名称</th><th>坐标</th><th>部署日期</th><th>状态</th></tr>
      <tr>
        <td>SG-001</td><td>凤凰山</td><td><code>44.52, 127.83</code></td><td>2026-03-15</td><td><span style="color:#27ae60;">运行中</span></td>
      </tr>
      <tr>
        <td>SG-003</td><td>贺兰山</td><td><code>38.78, 106.03</code></td><td>2026-04-20</td><td><span style="color:#c0392b;">任务完成</span></td>
      </tr>
      <tr>
        <td>SG-007</td><td>昆仑山</td><td><code>36.12, 94.55</code></td><td>2026-05-01</td><td><span style="color:#27ae60;">运行中</span></td>
      </tr>
      <tr>
        <td>SG-012</td><td>罗布泊</td><td><code>40.39, 90.22</code></td><td>2026-05-10</td><td><span style="color:#27ae60;">运行中</span></td>
      </tr>
      <tr>
        <td>SG-023</td><td>秦岭</td><td><code>33.25, 107.15</code></td><td>2026-05-15</td><td><span style="color:#e67e22;">信号异常</span></td>
      </tr>
    </table>
    <p style="font-size:0.72rem;color:#666;margin-top:6px;">
      共47个点位。上表仅列出关键点位。完整列表见附件。
    </p>
  </div>

  <!-- 古迹诱饵点位 -->
  <div class="card" style="margin-bottom: 12px; border-left: 3px solid var(--color-tag-ruins);">
    <h4>🏛️ 古迹诱饵点位（与信号点位坐标重合）</h4>
    <table style="font-size: 0.78rem;">
      <tr><th>诱饵名称</th><th>伪装类型</th><th>坐标</th><th>对应信号编号</th><th>诱捕状态</th></tr>
      <tr>
        <td>贺兰山未记录岩画群</td><td>偏远古迹</td><td><code>38.78, 106.03</code></td><td>SG-003</td><td><span style="color:#c0392b;">已完成（三尺）</span></td>
      </tr>
      <tr>
        <td>凤凰山古祭祀遗址</td><td>伪造遗址</td><td><code>44.52, 127.83</code></td><td>SG-001</td><td><span style="color:#e67e22;">待命</span></td>
      </tr>
      <tr style="opacity: 0.5;">
        <td>秦岭"唐代摩崖石刻"</td><td>虚构古迹</td><td><code>33.25, 107.15</code></td><td>SG-023</td><td><span style="color:#888;">已暴露</span></td>
      </tr>
      <tr>
        <td>神农架远古石阵</td><td>自然+人工</td><td><code>31.58, 110.42</code></td><td>SG-002</td><td><span style="color:#888;">暂停</span></td>
      </tr>
      <tr>
        <td>哀牢山古滇国祭祀台</td><td>伪造遗址</td><td><code>24.05, 101.67</code></td><td>—</td><td><span style="color:#e67e22;">待命</span></td>
      </tr>
    </table>
  </div>

  <div class="hidden-notice" style="margin-top: 16px;">
    <p style="margin-bottom: 4px;"><strong>💡 关键情报：</strong></p>
    <ul style="margin-bottom: 0; padding-left: 1.5em; color: #88d;">
      <li><strong>布景基地精确坐标：31.12, 111.45</strong>（鄂西废弃萤石矿）——这就是关押沈辞和其他受害者的地方。</li>
      <li>所有信号发射器点位与古迹诱饵点位坐标<strong>完全一致</strong>——证实了沈辞和林屿的交叉比对结论。</li>
      <li>贺兰山点位标记为"已完成"——沈辞在那里被伏击。</li>
      <li>秦岭点位标记为"已暴露"——因为沈辞和林屿都去了并发现是假的。</li>
      <li>将此数据与"深海猎手"叛变信息交叉比对——他整理的证据包中很可能包含这些坐标。</li>
    </ul>
  </div>
</HiddenLayout>
