---
// /hidden/operation — 作案流程手册
// 团伙标准操作流程文档，揭示完整的犯罪链条
import HiddenLayout from '../../components/HiddenLayout.astro';
const BASE = __BASE_PATH__;
---

<HiddenLayout title="作案流程手册">
  <div class="breadcrumb">
    <a href={`${BASE}hidden/admin/`} target="_blank">后台管理</a><span>›</span>
    作案流程手册
  </div>

  <h2 style="color: #c0392b; margin-bottom: 4px;">📁 作案流程手册（内部培训文档 v3.2）</h2>
  <p class="text-muted" style="margin-bottom: 16px;">最后修订：2026-01-15 · 分类：绝密 · 仅限核心成员查阅</p>

  <div class="hidden-warning">
    ⚠ 本手册为组织核心资产。任何未经授权的传播将导致立即清除。前成员"深海猎手"曾试图将此文档外传——已于2026年3月处理。以此为戒。
  </div>

  <!-- 六阶段流程 -->
  <div class="card" style="margin-bottom: 12px;">
    <h4>阶段一：潜伏观察（2-12周）</h4>
    <div style="font-size: 0.84rem; color: #aaa; line-height: 1.8;">
      <p><strong>目标：</strong>在钓鱼站点中识别潜在目标，建立信任。</p>
      <p><strong>操作要点：</strong></p>
      <ul>
        <li>使用看似正常的账号（如"山野探秘人"）参与社区讨论</li>
        <li>发布真实、有用的内容建立可信度（路线分享、装备评测等）</li>
        <li>观察活跃用户的：发帖频率、探访偏好、是否单独行动、社交圈大小</li>
        <li>记录每个潜在目标的<strong>弱点矩阵</strong>（见附件A）</li>
      </ul>
      <p><strong>筛选优先级：</strong></p>
      <ul>
        <li>✅ 优先：单独行动者、去偏远地点、社交圈小、非本地人、无军方/警方背景</li>
        <li>❌ 排除：多人同行者、有大量社交媒体粉丝、军人/警察/政府人员</li>
      </ul>
    </div>
  </div>

  <div class="card" style="margin-bottom: 12px;">
    <h4>阶段二：目标筛选与评估</h4>
    <div style="font-size: 0.84rem; color: #aaa; line-height: 1.8;">
      <p><strong>目标：</strong>从潜在目标中选出1-2人作为下一次行动的确定目标。</p>
      <p><strong>评估维度：</strong></p>
      <ul>
        <li>独行指数（1-10分）：是否习惯单独出行？</li>
        <li>偏远偏好（1-10分）：是否对偏远地点有明确偏好？</li>
        <li>社交隔离（1-10分）：失踪后有多少人会持续追问？</li>
        <li>专业背景威胁（-10到0分）：是否具备识别伪造内容的专业能力？<br />
          <span style="color:#c0392b;">⚠ 注意：目标"三尺"的专业背景（古迹/历史）评分应为-6——他有识别历史硬伤的能力。但他的出行偏好和社交隔离得分极高。综合评估后仍列为目标。此为风险决策案例。</span>
        </li>
      </ul>
    </div>
  </div>

  <div class="card" style="margin-bottom: 12px;">
    <h4>阶段三：匹配诱饵</h4>
    <div style="font-size: 0.84rem; color: #aaa; line-height: 1.8;">
      <p><strong>目标：</strong>根据目标的兴趣偏好，在导航站上推送匹配的"秘境"推荐。</p>
      <p><strong>诱饵类型：</strong></p>
      <ul>
        <li>古迹类 → 偏远古迹/未记录遗址（需配合假历史描述）</li>
        <li>外星类 → 信号热点/目击高发区（需配合信号发射器部署）</li>
        <li>自然类 → 未开发秘境/隐秘景观（无需额外布景，纯靠地点偏）</li>
      </ul>
      <p><strong>关键原则：</strong>推荐的点位必须是<strong>真实存在的偏远地点</strong>。不需要造假景——造假景成本高且容易穿帮。我们只需要目标到达那个地点。剩下的由现场人员处理。</p>
      <p><strong style="color:#c0392b;">⚠ 致命短板：</strong>我们对古迹/历史/天文等专业领域的描述常有硬伤。已被多名有专业背景的用户识破（包括目标"三尺"）。新版本手册要求：<strong>遇到专业背景过强的潜在目标，优先排除而非冒险诱捕</strong>。三尺案是一个教训——他的历史专业知识让他提前识破了我们的诱饵，差点暴露整个站点。</p>
    </div>
  </div>

  <div class="card" style="margin-bottom: 12px;">
    <h4>阶段四：引导前往</h4>
    <div style="font-size: 0.84rem; color: #aaa; line-height: 1.8;">
      <p><strong>目标：</strong>让目标"自己发现"点位并产生前往的意愿。</p>
      <ul>
        <li>通过站内推送、评论区暗示、私信"热心推荐"等方式引导</li>
        <li>⚠ 关键：让目标觉得是<strong>自己找到的</strong>——而非被引导的</li>
        <li>如果目标犹豫，可由潜伏账号私信提供"独家信息"或"组队邀请"来推动</li>
        <li>在目标决定前往后，潜伏账号可提供看似有用的建议（路线、装备）来<strong>确认其行程细节</strong></li>
      </ul>
    </div>
  </div>

  <div class="card" style="margin-bottom: 12px;">
    <h4>阶段五：线下伏击</h4>
    <div style="font-size: 0.84rem; color: #aaa; line-height: 1.8;">
      <p><strong>目标：</strong>在偏远地点安全、安静地完成捕获。</p>
      <ul>
        <li>至少提前 <strong>48 小时</strong>到达点位附近埋伏</li>
        <li>现场人员：2-3人（1人观察、1-2人行动）</li>
        <li>装备：麻醉枪、通讯设备、运输车辆（伪装为科考/施工车辆）</li>
        <li>目标到达后确认其身份 → 确认周边无目击者 → 快速行动</li>
        <li>捕获后<strong>立即清理现场</strong>：撤除埋伏痕迹、回收信号设备（如有）</li>
        <li><strong style="color:#c0392b;">⚠ 野外埋伏的痕迹最难清理</strong>——篝火、食物包装、烟头、设备残片。需双人交叉检查。</li>
      </ul>
    </div>
  </div>

  <div class="card" style="margin-bottom: 12px;">
    <h4>阶段六：清理痕迹与冷却</h4>
    <div style="font-size: 0.84rem; color: #aaa; line-height: 1.8;">
      <p><strong>目标：</strong>最小化事后暴露风险。</p>
      <ul>
        <li>得手后<strong>24小时内</strong>删除站内与该点位相关的推荐和引导内容</li>
        <li>目标的最后一篇帖文<strong>保留不删</strong>（删除反而可疑）</li>
        <li>潜伏账号继续在社区正常活动，观察舆论反应</li>
        <li>如出现质疑帖，由潜伏账号以"正常用户"身份进行舆论引导</li>
        <li>进入<strong>至少3个月</strong>冷却期——期间不进行新的诱捕</li>
      </ul>
      <p><strong>站点废弃标准：</strong></p>
      <ul>
        <li>捕获 <strong>2-5 人</strong>后废弃当前钓鱼站点</li>
        <li>废弃方式：停止更新内容、停止回复、让站点自然"死亡"</li>
        <li>⚠ 绝不突然关站——会引起受害者家属和警方的注意</li>
        <li>新站点使用全新域名、全新服务器、全新"站长"身份</li>
      </ul>
    </div>
  </div>

  <div class="card" style="border-left: 3px solid #c0392b;">
    <h4>📎 附件A：目标弱点矩阵（模板）</h4>
    <table style="font-size: 0.78rem;">
      <tr><th>维度</th><th>评分</th><th>说明</th></tr>
      <tr><td>独行指数</td><td>/10</td><td>历史出行记录中单独行动的比例</td></tr>
      <tr><td>偏远偏好</td><td>/10</td><td>对偏远、信号差地点的偏好程度</td></tr>
      <tr><td>社交隔离</td><td>/10</td><td>社交圈大小及失踪后追问者的数量</td></tr>
      <tr><td>非本地性</td><td>/10</td><td>目标常住地与探访地点的距离</td></tr>
      <tr><td>专业威胁</td><td>-10~0</td><td>专业背景对识别伪造内容的威胁程度</td></tr>
      <tr><td>媒体暴露</td><td>/10</td><td>是否有大量社交媒体粉丝</td></tr>
      <tr style="background: #1a0a0a;"><td colspan="3">
        <strong>案例：目标"三尺"（沈辞）</strong><br />
        独行指数：9 · 偏远偏好：9 · 社交隔离：7 · 非本地性：8 · 专业威胁：-6 · 媒体暴露：2<br />
        <strong>综合评估：高风险高回报。</strong>专业威胁评分低（意味着他容易识破诱饵），但其他维度得分极高。<br />
        最终决定：列为目标。结果：成功捕获，但他在出发前留了加密信息给signal_屿——这是专业威胁的后果。
      </td></tr>
    </table>
  </div>

  <div class="card" style="border-left: 3px solid #8b5a3a;">
    <h4>📎 附件B：市场术语对照表（内部培训用）</h4>
    <p style="font-size:0.78rem;color:#888;margin-bottom:10px;">以下为暗网市场的标准挂牌术语。新入岗运营人员须熟记，避免在客户沟通中混淆。</p>
    <table style="font-size: 0.76rem;">
      <tr><th style="width:18%;">市场术语</th><th style="width:22%;">字面含义（对外）</th><th>实际指代（内部）</th></tr>
      <tr><td><strong>龙骨</strong></td><td>古生物骨骼标本</td><td style="color:#c0392b;">人体骨骼/血型配型数据。完整度以"组"计。高价品类。</td></tr>
      <tr><td><strong>鲜源</strong></td><td>新鲜生物来源材料</td><td style="color:#c0392b;">人体器官（肾脏、肝脏、角膜等）。需冷链物流配合。以"件"计。</td></tr>
      <tr><td><strong>整件</strong></td><td>完整藏品/标本</td><td style="color:#c0392b;">整人出售——不拆解，保持完整状态移交买家。按用途分：劳力件/展示件/转运件。</td></tr>
      <tr><td><strong>拆解</strong></td><td>藏品拆分出售</td><td style="color:#c0392b;">将标的拆分为多个鲜源/龙骨分别出售。提高总收益，但需外部医疗团队配合。</td></tr>
      <tr><td><strong>野外现货</strong></td><td>野外采集的现货</td><td style="color:#c0392b;">已捕获、正在基地养护中的标的。可立即挂牌。</td></tr>
      <tr><td><strong>养护中</strong></td><td>藏品保养维护中</td><td style="color:#c0392b;">标的正在接受体检、HLA分型或术后恢复。暂不可出。</td></tr>
      <tr><td><strong>品级</strong></td><td>藏品质量等级</td><td style="color:#c0392b;">标的健康等级：A级（年轻、无基础病）→ S级（稀有血型或特殊HLA配型）。影响估价。</td></tr>
      <tr><td><strong>品相</strong></td><td>藏品外观完整度</td><td style="color:#c0392b;">标的的身体完整性和体能状态。完整·无损伤为最佳。</td></tr>
      <tr><td><strong>活体陈列</strong></td><td>活体展示/直播</td><td style="color:#c0392b;">将标的置于野外实景中进行直播展示。叠加体征数据供买家评估品相。即暗网直播频道。</td></tr>
      <tr><td><strong>出货</strong></td><td>藏品交付运输</td><td style="color:#c0392b;">将标的从基地移交给买家或跨境转运网络。分冷链出货（鲜源）和整件出货。</td></tr>
      <tr><td><strong>标的</strong></td><td>交易标的物</td><td style="color:#c0392b;">被挂牌出售的受害者。以SKU编号追踪。</td></tr>
    </table>
    <p style="font-size:0.7rem;color:#666;margin-top:8px;">
      ※ 此对照表为内部培训材料。严禁外传。客户统一使用市场术语沟通，不得在公开频道使用内部指代。
    </p>
  </div>
</HiddenLayout>
