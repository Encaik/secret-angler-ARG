---
// /hidden/operation — 标准操作流程（团伙内部SOP手册）
import HiddenLayout from '../../components/HiddenLayout.astro';
const BASE = __BASE_PATH__;
---

<HiddenLayout title="操作手册">
  <div class="breadcrumb">
    <a href={`${BASE}hidden/admin/`} target="_blank">管理后台</a><span>›</span>
    操作手册
  </div>

  <h2 style="color: #2c1810; margin-bottom: 4px;">标准操作流程（内部文件）</h2>
  <p class="text-muted" style="margin-bottom: 16px;">最后修订：2026-01-15 · 密级：内部 · 仅限核心人员</p>

  <div class="hidden-warning">
    ⚠ 本文件为组织核心操作流程。任何未经许可的外传将导致严厉处置。前成员郑义（深观）曾试图泄露本文件——已于2026年3月被处置。以此为戒。
  </div>

  <!-- 六步流程 -->
  <div class="card" style="margin-bottom: 12px;">
    <h4>一、目标筛选（2-12周）</h4>
    <div style="font-size: 0.84rem; color: #4a3728; line-height: 1.8;">
      <p><strong>目标：</strong>在论坛中识别潜在目标，建立信任。</p>
      <p><strong>方法：</strong></p>
      <ul>
        <li>以普通爱好者身份（如"外联人员"账号）参与论坛讨论</li>
        <li>发布真实、有用的帖文建立信誉（路线分享、装备评测等）</li>
        <li>观察活跃用户的：发帖频率、出行偏好、是否独行、社会关系广度</li>
        <li>为每位潜在目标填写<strong>目标评估量表</strong>（见附录A）</li>
      </ul>
      <p><strong>筛选优先级：</strong></p>
      <ul>
        <li>✓ 优先：独行者、偏好偏远地点者、社会关系少者、非本地人、无军警/政府背景者</li>
        <li>✗ 排除：多人同行者、社会关系广泛者、军人/警察/政府人员</li>
      </ul>
    </div>
  </div>

  <div class="card" style="margin-bottom: 12px;">
    <h4>二、目标评估</h4>
    <div style="font-size: 0.84rem; color: #4a3728; line-height: 1.8;">
      <p><strong>目标：</strong>从候选目标中选定1-2人，确定为下一轮行动对象。</p>
      <p><strong>评估维度：</strong></p>
      <ul>
        <li>独行倾向（1-10分）：是否惯于独自出行？</li>
        <li>偏远偏好（1-10分）：是否偏好偏远、信号差的探秘地点？</li>
        <li>社会关联（1-10分）：失踪后有多少人会持续追问？</li>
        <li>专业知识威胁（-10到0分）：是否有能识破我们伪造内容的专业能力？<br />
          <span style="color:#5c2e2e;">⚠ 注：沈辞的专业背景（古迹/历史）评分威胁-6——他有能力识别我们编造内容中的漏洞。但他的偏远偏好和独行倾向极高。综合评估后仍列为目标。这是一次高风险决策。</span>
        </li>
      </ul>
    </div>
  </div>

  <div class="card" style="margin-bottom: 12px;">
    <h4>三、兴趣引导</h4>
    <div style="font-size: 0.84rem; color: #4a3728; line-height: 1.8;">
      <p><strong>目标：</strong>根据目标的兴趣偏好，在论坛推送匹配的探秘地点信息。</p>
      <p><strong>引导类型：</strong></p>
      <ul>
        <li>古迹类 → 偏远古迹/未记录遗址（需配合我们编造的内容）</li>
        <li>天象类 → 信号热点/异常现象频发区（需配合信号灯阵列）</li>
        <li>自然类 → 未开发秘境/隐秘景点（无需额外布置，纯粹靠地点偏远）</li>
      </ul>
      <p><strong>核心原则：</strong>推荐的地点必须是<strong>真实存在的偏远地点</strong>。不需要伪造地点——伪造成本高且容易穿帮。我们只需要目标到达该地点。剩下的由行动组处理。</p>
      <p><strong style="color:#5c2e2e;">⚠ 筛选红线：</strong>目标专业知识威胁评分 ≥6 时，原则上<strong>排除而非冒险</strong>。古迹/历史/天文方向的内容编撰非我方专长，已被多次识破。甲辰003（三尺）即为教训——其人出发前已串联多源疑点，若非提前收网，后果严重。</p>
    </div>
  </div>

  <div class="card" style="margin-bottom: 12px;">
    <h4>四、诱导出行</h4>
    <div style="font-size: 0.84rem; color: #4a3728; line-height: 1.8;">
      <p><strong>目标：</strong>让目标"自己发现"地点并产生前往的意愿。</p>
      <ul>
        <li>通过论坛推送、评论区暗示、私信"热心推荐"等方式引导</li>
        <li>⚠ 关键：让目标觉得是<strong>自己找到的</strong>——而非被引导</li>
        <li>如果目标犹豫，可由外联人员私信提供"独家消息"或"结伴邀请"来推动</li>
        <li>目标决定出行后，外联人员可提供看似有益的出行建议（路线、装备）来<strong>确认其具体行程</strong></li>
      </ul>
    </div>
  </div>

  <div class="card" style="margin-bottom: 12px;">
    <h4>五、现场行动</h4>
    <div style="font-size: 0.84rem; color: #4a3728; line-height: 1.8;">
      <p><strong>目标：</strong>在偏远地点安全、隐蔽地完成行动。</p>
      <ul>
        <li>至少提前 <strong>48小时</strong> 到达地点附近埋伏</li>
        <li>行动组：2-3人（1人望风、1-2人执行）</li>
        <li>装备：麻醉枪、通讯设备、伪装车辆（科考/施工外观）</li>
        <li>目标到达后确认身份 → 确认周边无目击者 → 迅速行动</li>
        <li>行动完成后<strong>立即清理现场</strong>：撤除埋伏痕迹、回收信号灯（如有）</li>
        <li><strong style="color:#5c2e2e;">⚠ 野外的行动痕迹最难清理</strong>——篝火、食物残渣、烟蒂、装备碎片。需两人交叉检查。</li>
      </ul>
    </div>
  </div>

  <div class="card" style="margin-bottom: 12px;">
    <h4>六、善后处理</h4>
    <div style="font-size: 0.84rem; color: #4a3728; line-height: 1.8;">
      <p><strong>目标：</strong>最小化事后暴露风险。</p>
      <ul>
        <li>行动完成后<strong>12小时内</strong>删除论坛上与该地点相关的所有引导帖文</li>
        <li>目标最后的帖文<strong>保留不删</strong>（删除反而可疑）</li>
        <li>外联人员继续在论坛正常活动，观察舆论</li>
        <li>如有质疑帖文，由外联人员以"普通用户"身份进行舆论引导</li>
        <li>进入<strong>至少三个月</strong>冷却期——期间禁止新行动</li>
      </ul>
      <p><strong>站点废弃准则：</strong></p>
      <ul>
        <li>行动 <strong>2-5 人</strong>后废弃当前论坛站点</li>
        <li>废弃方式：停止更新、停止回复，让站点自然"沉寂"</li>
        <li>⚠ 绝不突然关闭——会引起受害者家属和执法部门注意</li>
        <li>新站点使用全新域名、全新数据库、全新"站长"身份</li>
      </ul>
    </div>
  </div>

  <div class="card" style="border-left: 3px solid #8b6914;">
    <h4>附录A：目标评估量表</h4>
    <table style="font-size: 0.78rem;">
      <tr><th>维度</th><th>评分</th><th>说明</th></tr>
      <tr><td>独行倾向</td><td>/10</td><td>过往出行中独自行动的比例</td></tr>
      <tr><td>偏远偏好</td><td>/10</td><td>对偏远、信号差地点的偏好程度</td></tr>
      <tr><td>社会关联</td><td>/10</td><td>社会中会追问其下落的人际网络</td></tr>
      <tr><td>非本地性</td><td>/10</td><td>目标常住地与行动地点的距离</td></tr>
      <tr><td>专业知识威胁</td><td>-10~0</td><td>专业知识对我们编造内容的识破能力</td></tr>
      <tr><td>网络声量</td><td>/10</td><td>社交媒体上的关注者规模</td></tr>
      <tr style="background: #faf6ee;"><td colspan="3">
        <strong>案例：沈辞（代号：三尺）</strong><br />
        独行倾向：9 · 偏远偏好：9 · 社会关联：7 · 非本地性：8 · 专业知识威胁：-6 · 网络声量：2<br />
        <strong>综合评估：高风险决策。</strong>专业知识威胁低（意味他容易识破我们的编造内容），但其余维度极高。<br />
        最终决定：列入目标。结果：行动成功，但他在出行前留了加密证据给林屿——这就是低估他专业能力的后果。
      </td></tr>
    </table>
  </div>

  <div class="card" style="border-left: 3px solid #a0702c;">
    <h4>附录B：操作代号对照表（全员必读）</h4>
    <p style="font-size:0.78rem;color:#6b5d4a;margin-bottom:10px;">以下为暗网市场（因缘海）的标准操作代号。所有人员必须熟记，禁止在公开场合使用真实含义。</p>
    <table style="font-size: 0.76rem;">
      <tr><th style="width:18%;">操作代号</th><th style="width:22%;">对外含义</th><th>真实含义（内部）</th></tr>
      <tr><td><strong>金刚舍利</strong></td><td>修行者遗骨结晶</td><td style="color:#5c2e2e;">人体骨骼/血型配型数据。完整度以"具"计。高价值品。</td></tr>
      <tr><td><strong>甘露</strong></td><td>诸天所赐长生药</td><td style="color:#5c2e2e;">人体器官（肾脏、肝脏、角膜等）。需冷链运输。以"味"计。</td></tr>
      <tr><td><strong>金身渡化</strong></td><td>肉身菩萨度众生</td><td style="color:#5c2e2e;">整人移交——不拆分，保持完整身体移交给买家。按用途分：劳动/展示/转运。</td></tr>
      <tr><td><strong>分身渡化</strong></td><td>一身化现多身</td><td style="color:#5c2e2e;">将身体拆分为多份器官/骨骼分别出售。增加总收入，但需医生配合。</td></tr>
      <tr><td><strong>灵墟现货</strong></td><td>灵墟现前法器</td><td style="color:#5c2e2e;">已行动、正在基地中关押的目标。可即时上架。</td></tr>
      <tr><td><strong>闭关中</strong></td><td>弟子闭关修行中</td><td style="color:#5c2e2e;">目标正在接受体检、配型或术后恢复。暂不可出售。</td></tr>
      <tr><td><strong>根器</strong></td><td>修行者资质</td><td style="color:#5c2e2e;">目标健康等级：甲级（年轻、无慢性病）→ 殊胜级（稀有血型或特殊配型）。影响定价。</td></tr>
      <tr><td><strong>法相</strong></td><td>修行者威仪外表</td><td style="color:#5c2e2e;">目标身体完整度与体能状态。完整·无损为最高等级。</td></tr>
      <tr><td><strong>法身示现</strong></td><td>佛法示现于世间</td><td style="color:#5c2e2e;">将目标置于实景中进行展示直播。叠加生理监测数据供买家评估身体状况。即暗网直播频道。</td></tr>
      <tr><td><strong>流通</strong></td><td>法器流转结缘</td><td style="color:#5c2e2e;">将目标从基地移交买家或跨境转运网络。分冷链运输（器官）和整人运输。</td></tr>
      <tr><td><strong>缘号</strong></td><td>善缘编号</td><td style="color:#5c2e2e;">被挂牌出售的目标。以缘号追踪。</td></tr>
    </table>
    <p style="font-size:0.7rem;color:#b0a090;margin-top:8px;">
      ※ 本对照表为内部资料，严禁外传。对外沟通统一使用代号栏术语，不得在公开论坛使用真实含义。
    </p>
  </div>

</HiddenLayout>
