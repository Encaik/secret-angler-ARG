<script>

  const VALID_ACCOUNTS: Record<string, string> = {
    'DR-2026-03': 'rift0603',
  };

  function doLogin() {
    const username = (document.getElementById('panlongxia-username') as HTMLInputElement).value.trim();
    const password = (document.getElementById('panlongxia-password') as HTMLInputElement).value;
    const errorEl = document.getElementById('login-error');
    const publicView = document.getElementById('public-view');
    const loginSection = document.getElementById('login-section');
    const content = document.getElementById('vip-content');
    const headerUser = document.getElementById('header-user');

    if (VALID_ACCOUNTS[username] && VALID_ACCOUNTS[username] === password) {
      if (errorEl) errorEl.style.display = 'none';
      if (publicView) publicView.style.display = 'none';
      if (loginSection) loginSection.style.display = 'none';
      if (content) content.style.display = 'block';
      if (headerUser) headerUser.textContent = username;

      const stored = localStorage.getItem('arg_progress');
      if (stored) {
        const p = JSON.parse(stored);
        if (!p.solvedPuzzles) p.solvedPuzzles = {};
        p.solvedPuzzles['stage4_darknet_access'] = true;
        if (!p.discoveredClues) p.discoveredClues = [];
        if (!p.discoveredClues.includes('darknet_marketplace')) {
          p.discoveredClues.push('darknet_marketplace');
          p.explorationProgress = (p.explorationProgress || 0) + 20;
        }
        if (!p.discoveredPages) p.discoveredPages = [];
        if (!p.discoveredPages.includes('/hidden/panlongxia')) {
          p.discoveredPages.push('/hidden/panlongxia');
        }
        localStorage.setItem('arg_progress', JSON.stringify(p));
      }
    } else {
      if (errorEl) {
        errorEl.textContent = '账号或密码错误。';
        errorEl.style.display = 'block';
      }
    }
  }

  function tryAutoFill() {
    const stored = localStorage.getItem('arg_progress');
    if (stored) {
      const p = JSON.parse(stored);
      if (p.darknetAccount) {
        const u = document.getElementById('panlongxia-username') as HTMLInputElement;
        const pw = document.getElementById('panlongxia-password') as HTMLInputElement;
        if (u) u.value = p.darknetAccount.account || '';
        if (pw) pw.value = p.darknetAccount.password || '';
      }
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    tryAutoFill();

    // 显示登录区域
    document.getElementById('show-login-btn')?.addEventListener('click', () => {
      const publicView = document.getElementById('public-view');
      const loginSection = document.getElementById('login-section');
      if (publicView) publicView.style.display = 'none';
      if (loginSection) loginSection.style.display = 'block';
    });

    // 返回公开视图
    document.getElementById('back-to-public')?.addEventListener('click', () => {
      const publicView = document.getElementById('public-view');
      const loginSection = document.getElementById('login-section');
      if (publicView) publicView.style.display = 'block';
      if (loginSection) loginSection.style.display = 'none';
    });

    // 退出登录
    document.getElementById('vip-logout-btn')?.addEventListener('click', () => {
      const publicView = document.getElementById('public-view');
      const content = document.getElementById('vip-content');
      if (publicView) publicView.style.display = 'block';
      if (content) content.style.display = 'none';
    });

    document.getElementById('panlongxia-login-btn')?.addEventListener('click', doLogin);
    document.getElementById('panlongxia-password')?.addEventListener('keydown', (e) => { if (e.key === 'Enter') doLogin(); });
    document.getElementById('panlongxia-username')?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') (document.getElementById('panlongxia-password') as HTMLInputElement)?.focus();
    });

    // 标签切换
    document.querySelectorAll('.vip-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const tabName = (tab as HTMLElement).dataset.tab;
        document.querySelectorAll('.vip-tab').forEach(t => {
          (t as HTMLElement).style.color = '#888';
          (t as HTMLElement).style.borderBottom = 'none';
        });
        (tab as HTMLElement).style.color = '#c41230';
        (tab as HTMLElement).style.borderBottom = '2px solid #c41230';
        ['market','live','history','wallet'].forEach(id => {
          const el = document.getElementById('tab-' + id);
          if (el) el.style.display = id === tabName ? 'block' : 'none';
        });
      });
    });
  });
</script>
