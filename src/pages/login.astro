---
// 登录页 — 模拟浏览器"保存的密码"自动填充
// 玩家点击signal_屿 → 自动填入 → 登录
import Layout from '../components/Layout.astro';
---

<Layout title="登录">
  <div style="max-width: 420px; margin: 60px auto;">

    <h2 style="text-align: center; margin-bottom: 24px;">登录探秘者联盟</h2>

    <!-- 模拟浏览器"保存的密码"提示 -->
    <div id="saved-passwords" class="card" style="background: #fafafa; border: 1px solid #d0d0d0; margin-bottom: 20px;">
      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="#5a5a5a"><path d="M12 1a5 5 0 0 1 5 5v3h2a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V11a2 2 0 0 1 2-2h2V6a5 5 0 0 1 5-5zm0 2a3 3 0 0 0-3 3v3h6V6a3 3 0 0 0-3-3z"/></svg>
        <span style="font-size: 0.85rem; color: #5a5a5a;">浏览器已保存的密码</span>
      </div>
      <div class="saved-item" data-username="lyu" data-password="starchaser24" style="display: flex; align-items: center; justify-content: space-between; padding: 8px 10px; border: 1px solid #e0e0e0; border-radius: 4px; cursor: pointer; background: #fff; transition: background 0.15s;">
        <div>
          <div style="font-size: 0.9rem; font-weight: bold;">lyu</div>
          <div style="font-size: 0.75rem; color: #999;">探秘者联盟 · 上次使用：今天</div>
        </div>
        <span style="font-size: 0.75rem; color: #1a5276;">▸ 自动填充</span>
      </div>
    </div>

    <!-- 登录表单 -->
    <form id="login-form">
      <label style="display: block; margin-bottom: 12px;">
        账号
        <input type="text" id="username" placeholder="输入账号" autocomplete="off" style="max-width: 100%;" />
      </label>
      <label style="display: block; margin-bottom: 16px;">
        密码
        <input type="password" id="password" placeholder="输入密码" style="max-width: 100%;" />
      </label>
      <button type="submit" style="width: 100%; padding: 10px; font-size: 1rem; background: var(--color-bg-dark); color: #e0dcd5; border: none; cursor: pointer; border-radius: var(--radius-sm);">
        登录
      </button>
    </form>
    <p id="login-error" style="color: #c0392b; font-size: 0.82rem; margin-top: 8px; display: none;"></p>
    <p id="login-success" style="color: #27ae60; font-size: 0.82rem; margin-top: 8px; display: none;"></p>

    <p style="text-align: center; margin-top: 20px;">
      <a href="/home/" target="_blank" style="font-size: 0.85rem; color: var(--color-text-muted);">暂不登录，先随便看看</a>
    </p>
  </div>
</Layout>

<script>
  // 已验证的账号密码
  const CREDENTIALS: Record<string, { password: string; redirect: string }> = {
    'lyu': { password: 'starchaser24', redirect: '/inbox/' },
    'shenci': { password: 'helanshan02', redirect: '/user/shenci/' },
  };

  // 点击"自动填充"
  document.querySelectorAll('.saved-item').forEach(item => {
    item.addEventListener('click', () => {
      const username = (item as HTMLElement).dataset.username || '';
      const password = (item as HTMLElement).dataset.password || '';
      (document.getElementById('username') as HTMLInputElement).value = username;
      (document.getElementById('password') as HTMLInputElement).value = password;
      // 视觉反馈
      item.style.background = '#e8f4e8';
      item.querySelector('span')!.textContent = '✓ 已填充';
    });
  });

  // 登录
  document.getElementById('login-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const username = (document.getElementById('username') as HTMLInputElement).value.trim();
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const errorEl = document.getElementById('login-error');
    const successEl = document.getElementById('login-success');

    const cred = CREDENTIALS[username];
    if (cred && cred.password === password) {
      localStorage.setItem('arg_logged_in', 'true');
      localStorage.setItem('arg_username', username);

      // 初始化或更新进度
      let progress = JSON.parse(localStorage.getItem('arg_progress') || '{}');
      if (!progress.discoveredPages) {
        progress = {
          discoveredPages: ['/', '/community/post/shenci-final/', '/login/'],
          discoveredClues: [],
          solvedPuzzles: {},
          explorationProgress: 5,
          currentStage: 1,
          hasFullEvidence: false,
          hasAlertedPolice: false,
          hasRescuedRoommate: false,
          playerTargeted: false,
          ending: null,
          startedAt: Date.now(),
        };
      }
      // 记录登录
      if (!progress.discoveredClues) progress.discoveredClues = [];
      if (!progress.discoveredClues.includes(`login_${username}`)) {
        progress.discoveredClues.push(`login_${username}`);
      }
      localStorage.setItem('arg_progress', JSON.stringify(progress));

      // 显示成功提示后跳转
      if (successEl) {
        successEl.textContent = `✓ 登录成功：${username}`;
        successEl.style.display = 'block';
      }
      setTimeout(() => {
        window.location.href = cred.redirect;
      }, 600);
    } else {
      if (errorEl) {
        errorEl.textContent = '账号或密码错误。';
        errorEl.style.display = 'block';
      }
    }
  });

  // 后期线索标记：当玩家发现沈辞账号后，这里也会出现保存的密码
  const discoveredShenci = JSON.parse(localStorage.getItem('arg_progress') || '{}')
    .discoveredClues?.includes('shenci_credentials');
  if (discoveredShenci) {
    const container = document.getElementById('saved-passwords');
    if (container) {
      const shenciItem = document.createElement('div');
      shenciItem.className = 'saved-item';
      shenciItem.dataset.username = 'shenci';
      shenciItem.dataset.password = 'helanshan02';
      shenciItem.style.cssText = 'display: flex; align-items: center; justify-content: space-between; padding: 8px 10px; border: 1px solid #e0e0e0; border-radius: 4px; cursor: pointer; background: #fff; margin-top: 6px;';
      shenciItem.innerHTML = `
        <div>
          <div style="font-size: 0.9rem; font-weight: bold;">shenci</div>
          <div style="font-size: 0.75rem; color: #999;">探秘者联盟 · 已解锁</div>
        </div>
        <span style="font-size: 0.75rem; color: #1a5276;">▸ 自动填充</span>
      `;
      shenciItem.addEventListener('click', () => {
        (document.getElementById('username') as HTMLInputElement).value = '地下三尺';
        (document.getElementById('password') as HTMLInputElement).value = 'helanshan02';
        shenciItem.style.background = '#e8f4e8';
        (shenciItem.querySelector('span') as HTMLElement).textContent = '✓ 已填充';
      });
      container.appendChild(shenciItem);
    }
  }
</script>

<style>
  .saved-item:hover { background: #f0f8f0 !important; }
  #login-form input {
    font-size: 0.95rem; padding: 9px 12px;
  }
  #login-form button:hover {
    background: #2a2d35; color: #fff;
  }
</style>
