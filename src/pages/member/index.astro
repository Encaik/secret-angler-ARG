---
// /member/ — 会员专区入口
// 如果已通过"深海裂隙2026"解锁，直接跳转到云盘共享页
import Layout from '../../components/Layout.astro';
const BASE = __BASE_PATH__;
---

<Layout title="会员专区">
  <div class="breadcrumb">
    <a href={`${BASE}home/`} target="_blank">首页</a><span>›</span>
    <a href={`${BASE}community/`} target="_blank">探秘者社区</a><span>›</span>
    会员专区
  </div>

  <div class="card" style="text-align: center; padding: 40px; max-width: 500px; margin: 40px auto;">
    <h2>🔒 会员专区</h2>
    <hr />
    <p class="text-muted">此板块需要会员权限。请通过社区中的线索获取访问密钥。</p>
    <div style="margin-top: 20px;">
      <a href={`${BASE}community/`} target="_blank" style="display: inline-block; padding: 10px 32px; background: var(--color-bg-dark); color: #e0dcd5; text-decoration: none; border-radius: var(--radius-sm);">
        返回社区 →
      </a>
    </div>
  </div>
</Layout>

<script is:inline>
  (function() {
    var progress = JSON.parse(localStorage.getItem('arg_progress') || '{}');
    var hasAccess = !!(progress.solvedPuzzles && progress.solvedPuzzles['stage1_page_header_password']);
    if (hasAccess) {
      var BASE = window.__BASE__ || '/';
      window.location.replace(BASE + 'share/');
    }
  })();
</script>
