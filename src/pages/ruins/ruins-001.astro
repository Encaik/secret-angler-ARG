---
// /ruins/ruins-001 — 贺兰山岩画未记录区（重要页面）
import Layout from '../../components/Layout.astro';
const BASE = __BASE_PATH__;
---

<Layout title="贺兰山岩画未记录区">
  <div class="breadcrumb">
    <a href={`${BASE}home/`} target="_blank">首页</a><span>›</span><a href={`${BASE}ruins/`} target="_blank">古迹秘境</a
    ><span>›</span>贺兰山岩画未记录区
  </div>
  <div class="location-hero mountains"></div>
  <article>
    <h1>贺兰山岩画未记录区</h1>
    <div class="post-meta">宁夏·银川 · 难度：中等 · 最近探访：地下三尺、废弃中 · 发布于 2026-04-10</div>
    <hr />
    <p>
      贺兰山深处发现一处未在图录中收录的<strong>岩画群</strong
      >。岩画内容与已知的西夏风格迥异——疑似更早期文明的遗存。图案中有酷似"天外来客"的人形图腾，线条粗犷抽象，与南方彩绘风格完全不同。坐标
      <strong>38.78, 106.03</strong>。
    </p>
    <p>
      银川出发，西夏区方向进山，沿干沟徒步约六公里，翻过海拔1800米左右的垭口到达岩画所在的崖面。沿途有明显的牧道可以跟随。入口隐蔽，需向导带路。主崖面和两条侧沟都有分布。
    </p>
    <p>
      需要注意的是夏季蝮蛇活跃，<strong>务必带蛇药</strong
      >。水源地距离岩画区约一公里，扎营需要提前备水。附近手机信号不稳定，建议下载离线地图。
    </p>
    <div class="post-meta" style="margin-top:16px;">
      标签：<span class="tag tag-ruins">古迹秘境</span>
      <span class="tag tag-ruins">岩画</span>
    </div>
  </article>
</Layout>
