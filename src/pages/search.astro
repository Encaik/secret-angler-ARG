---
// /search — 搜索结果页（独立页面，非弹窗）
// 历史存档内容仅通过此页面可见
import Layout from '../components/Layout.astro';
import {
  ARCHIVED_CONTENT,
  MOCK_RESULTS,
  HIDDEN_PAGE_CACHE,
  USER_SEARCH,
  SEARCH_TOKEN,
  SEARCH_SUGGESTIONS,
  PAGE_TITLES,
} from '../data/search-data';
const BASE = __BASE_PATH__;
---

<Layout title="搜索">
  <div class="breadcrumb">
    <a href={`${BASE}home/`} target="_blank">首页</a><span>›</span>
    搜索
  </div>

  <!-- 搜索框 -->
  <div style="margin: 0 auto 0;">
    <div style="display: flex; gap: 8px;">
      <input
        type="text"
        id="search-page-input"
        placeholder="输入关键词搜索站内内容……"
        style="flex: 1; max-width: 100%; font-size: 1rem; padding: 10px 14px;"
      />
      <button
        id="search-page-btn"
        style="padding: 10px 24px; font-size: 1rem; background: var(--color-bg-dark); color: #e0dcd5; border: none; cursor: pointer; border-radius: var(--radius-sm); white-space: nowrap;"
      >
        🔍 搜索
      </button>
    </div>
  </div>

  <hr style="margin: 20px 0;" />

  <!-- 搜索结果区域 -->
  <div id="search-results-area" style="margin: 0 auto;">
    <p class="text-muted" id="search-status">正在搜索……</p>
    <div id="search-results-list"></div>
  </div>
</Layout>

<script
  is:inline
  define:vars={{
    archivedContentJson: JSON.stringify(ARCHIVED_CONTENT),
    mockResultsJson: JSON.stringify(MOCK_RESULTS),
    hiddenPageCacheJson: JSON.stringify(HIDDEN_PAGE_CACHE),
    userSearchJson: JSON.stringify(USER_SEARCH),
    searchSuggestionsJson: JSON.stringify(SEARCH_SUGGESTIONS),
    pageTitlesJson: JSON.stringify(PAGE_TITLES),
    searchToken: SEARCH_TOKEN,
    basePath: BASE,
  }}
>
  // @ts-nocheck — define:vars 变量不在 TS 作用域内
  // BASE 路径前缀，通过 define:vars 传入（define:vars 脚本内 Vite define 不会被替换，必须通过 vars 传入）
  const BASE = basePath;
  // 从 Astro 服务端注入的搜索数据
  const ARCHIVED_CONTENT = JSON.parse(archivedContentJson);
  const MOCK_RESULTS = JSON.parse(mockResultsJson);
  const HIDDEN_PAGE_CACHE = JSON.parse(hiddenPageCacheJson);
  const USER_SEARCH = JSON.parse(userSearchJson);
  const SEARCH_SUGGESTIONS = JSON.parse(searchSuggestionsJson);
  const PAGE_TITLES = JSON.parse(pageTitlesJson);
  const SEARCH_TOKEN = searchToken;

  // 搜索权限：访问码 + 方括号双重条件，或已持久化提权
  function hasElevatedSearchAccess() {
    return localStorage.getItem('search_access_elevated') === 'true';
  }

  function grantElevatedSearchAccess() {
    localStorage.setItem('search_access_elevated', 'true');
  }

  function getQuery() {
    var params = new URLSearchParams(window.location.search);
    return params.get('q') || '';
  }

  function findArchivedContent(query) {
    var results = [];
    var lowerQuery = query.toLowerCase();
    var entries = Object.entries(ARCHIVED_CONTENT);

    for (var i = 0; i < entries.length; i++) {
      var keyword = entries[i][0];
      var posts = entries[i][1];
      if (lowerQuery.includes(keyword.toLowerCase())) {
        for (var j = 0; j < posts.length; j++) {
          var post = posts[j];
          if (
            !results.find(function (r) {
              return r.title === post.title && r.date === post.date;
            })
          ) {
            results.push(post);
          }
        }
      }
    }

    var cluePosts = results.filter(function (p) {
      return p.isClue;
    });
    var normalPosts = results.filter(function (p) {
      return !p.isClue;
    });
    return cluePosts.concat(normalPosts);
  }

  function findUserResults(query) {
    var results = [];
    var lowerQuery = query.toLowerCase();
    var entries = Object.entries(USER_SEARCH);
    var seen = [];

    for (var i = 0; i < entries.length; i++) {
      var keyword = entries[i][0];
      var user = entries[i][1];
      if (lowerQuery.includes(keyword.toLowerCase())) {
        if (seen.indexOf(user.account) === -1) {
          seen.push(user.account);
          results.push(user);
        }
      }
    }

    return results;
  }

  function renderResults(query) {
    var statusEl = document.getElementById('search-status');
    var listEl = document.getElementById('search-results-list');

    if (!query) {
      statusEl.textContent = '请输入关键词进行搜索。';
      listEl.innerHTML = `
        <div class="card" style="text-align:center;padding:24px;">
          <p class="text-muted">🔍 在站内搜索帖文、动态和探秘笔记</p>
          <p style="font-size:0.82rem;color:var(--color-text-muted);">
            试试搜索：<a href="${BASE}search/?q=沈辞">沈辞</a> ·
            <a href="${BASE}search/?q=地下三尺">地下三尺</a> ·
            <a href="${BASE}search/?q=贺兰山">贺兰山</a> ·
            <a href="${BASE}search/?q=外星">外星</a> ·
            <a href="${BASE}search/?q=加密">加密</a>
          </p>
        </div>
      `;
      return;
    }

    // 1. 历史存档检索
    const archived = findArchivedContent(query);

    // 2. 隐藏页面缓存检索（双重条件：访问码 kd7f3g + 方括号[关键词]，或已持久化提权）
    var cachedPages = [];
    var hasToken = query.includes(SEARCH_TOKEN);
    var bracketMatch = query.match(/\[(.+?)\]/);
    var elevatedAccess = (hasToken && bracketMatch !== null) || hasElevatedSearchAccess();

    if (elevatedAccess) {
      var cacheEntries = Object.entries(HIDDEN_PAGE_CACHE);
      for (var ci = 0; ci < cacheEntries.length; ci++) {
        var cacheKeyword = cacheEntries[ci][0];
        var cacheEntry = cacheEntries[ci][1];
        if (query.includes(cacheKeyword)) {
          cachedPages.push(cacheEntry);
        }
      }

      // 首次通过 访问码+方括号+匹配成功 时持久化提权
      if (hasToken && bracketMatch && cachedPages.length > 0 && !hasElevatedSearchAccess()) {
        grantElevatedSearchAccess();
      }
    }

    // 3. 页面导航
    var pageResults = [];
    var mockEntries = Object.entries(MOCK_RESULTS);
    for (var mi = 0; mi < mockEntries.length; mi++) {
      var term = mockEntries[mi][0];
      var pages = mockEntries[mi][1];
      if (query.includes(term)) {
        for (var pj = 0; pj < pages.length; pj++) {
          if (pageResults.indexOf(pages[pj]) === -1) {
            pageResults.push(pages[pj]);
          }
        }
      }
    }

    // 4. 用户搜索
    var userResults = findUserResults(query);

    // 无结果
    if (archived.length === 0 && cachedPages.length === 0 && pageResults.length === 0 && userResults.length === 0) {
      statusEl.textContent = `未找到与"${query}"相关的结果。请尝试其他关键词。`;
      listEl.innerHTML = `
        <div class="card" style="text-align:center;padding:24px;">
          <p class="text-muted">🔍 没有找到匹配的内容</p>
          <p style="font-size:0.82rem;color:var(--color-text-muted);">
            试试搜索：<a href="${BASE}search/?q=沈辞">沈辞</a> ·
            <a href="${BASE}search/?q=地下三尺">地下三尺</a> ·
            <a href="${BASE}search/?q=贺兰山">贺兰山</a> ·
            <a href="${BASE}search/?q=外星">外星</a> ·
            <a href="${BASE}search/?q=加密">加密</a>
          </p>
        </div>
      `;
      return;
    }

    var totalResults = archived.length + cachedPages.length + pageResults.length + userResults.length;
    statusEl.textContent = `找到约 ${totalResults} 条结果`;

    let html = '';

    // 用户搜索结果（优先显示）
    if (userResults.length > 0) {
      html += `<h3 style="margin-bottom:8px;">👤 用户（${userResults.length} 位）</h3>`;
      html += userResults
        .map(function (u) {
          return `
          <div class="card" style="margin-bottom:8px;padding:10px;display:flex;align-items:center;gap:12px;">
            <div style="width:44px;height:44px;background:var(--color-bg-dark);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0;">
              👤
            </div>
            <div style="flex:1;min-width:0;">
              <div style="display:flex;align-items:baseline;gap:8px;margin-bottom:2px;">
                <a href="${BASE}${u.pageUrl.replace(/^\//, '')}" target="_blank" style="font-size:0.92rem;font-weight:600;">${u.displayName}</a>
                <span class="text-muted" style="font-size:0.75rem;">账号：${u.account}</span>
                ${u.realName ? `<span class="text-muted" style="font-size:0.75rem;">（${u.realName}）</span>` : ''}
              </div>
              <p style="font-size:0.8rem;color:var(--color-text-secondary);margin:0;line-height:1.5;">${u.bio}</p>
              <span class="text-muted" style="font-size:0.7rem;">注册于 ${u.joinedDate}</span>
            </div>
          </div>
        `;
        })
        .join('');
    }

    // 隐藏页面缓存（优先显示，因为这些是玩家要找的关键入口）
    if (cachedPages.length > 0) {
      html += `<h3 style="margin-bottom:8px;">🌐 页面缓存（${cachedPages.length} 条）</h3>`;
      html += cachedPages
        .map(function (p) {
          var borderStyle = p.isClue ? 'border-left: 3px solid var(--color-accent);' : '';
          var titleHtml = p.pageUrl
            ? `<a href="${BASE}${p.pageUrl.replace(/^\//, '')}" target="_blank" style="color: var(--color-accent);">${p.title}</a>`
            : p.title;
          var authorHtml = p.authorUrl
            ? `<strong><a href="${BASE}${p.authorUrl.replace(/^\//, '')}" target="_blank">${p.author}</a></strong>`
            : `<span class="text-muted">${p.author}</span>`;
          return `
          <div class="card" style="margin-bottom:8px;padding:10px;${borderStyle}">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
              ${authorHtml}
              <span class="text-muted" style="font-size:0.75rem;">${p.date}</span>
            </div>
            <div style="font-size:0.88rem;font-weight:500;margin-bottom:4px;">${titleHtml}</div>
            <p style="font-size:0.84rem;margin:0;line-height:1.6;">${p.content}</p>
          </div>
        `;
        })
        .join('');
    }

    // 历史存档
    if (archived.length > 0) {
      html += `<h3 style="margin-bottom:8px;">📜 历史存档（${archived.length} 条）</h3>`;
      html += archived
        .map(function (p) {
          var borderStyle = p.isClue ? 'border-left: 3px solid var(--color-accent);' : '';
          var titleHtml = p.pageUrl
            ? `<a href="${BASE}${p.pageUrl.replace(/^\//, '')}" target="_blank" style="color: var(--color-accent);">${p.title}</a>`
            : p.title;
          return `
          <div class="card" style="margin-bottom:8px;padding:10px;${borderStyle}">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
              <strong><a href="${BASE}${p.authorUrl.replace(/^\//, '')}" target="_blank">${p.author}</a></strong>
              <span class="text-muted" style="font-size:0.75rem;">${p.date}</span>
            </div>
            <div style="font-size:0.88rem;font-weight:500;margin-bottom:4px;">${titleHtml}</div>
            <p style="font-size:0.84rem;margin:0;line-height:1.6;">${p.content}</p>
          </div>
        `;
        })
        .join('');
      html += `<p class="text-muted" style="font-size:0.72rem;margin-top:4px;">—— 以上为历史存档内容，数据来源为搜索引擎快照与站点缓存 ——</p>`;
    }

    // 页面导航
    if (pageResults.length > 0) {
      html += `<h3 style="margin-top:16px;margin-bottom:8px;">📂 相关板块（${pageResults.length}）</h3>`;
      html += pageResults
        .map((url) => {
          var title = PAGE_TITLES[url] || url;
          return `
        <div class="card" style="margin-bottom:6px;padding:8px 12px;">
          <a href="${BASE}${url.replace(/^\//, '')}" target="_blank" style="font-size:0.88rem;font-weight:500;">${title}</a>
          <span class="text-muted" style="font-size:0.72rem;display:block;">${url}</span>
        </div>
      `;
        })
        .join('');
    }

    listEl.innerHTML = html;
  }

  // ========== 初始化 ==========
  const query = getQuery();
  var inputEl = document.getElementById('search-page-input');
  var btnEl = document.getElementById('search-page-btn');

  if (query) {
    inputEl.value = query;
  }

  renderResults(query);

  // 搜索按钮
  btnEl.addEventListener('click', () => {
    const q = inputEl.value.trim();
    if (q) {
      const newUrl = `${BASE}search/?q=${encodeURIComponent(q)}`;
      window.history.pushState({}, '', newUrl);
      renderResults(q);
    }
  });

  // 回车
  inputEl.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const q = inputEl.value.trim();
      if (q) {
        const newUrl = `${BASE}search/?q=${encodeURIComponent(q)}`;
        window.history.pushState({}, '', newUrl);
        renderResults(q);
      }
    }
  });

  // 记录搜索
  const progress = JSON.parse(localStorage.getItem('arg_progress') || '{}');
  if (!progress.discoveredClues) progress.discoveredClues = [];
  const clueKey = `search_${query}`;
  if (query && !progress.discoveredClues.includes(clueKey)) {
    progress.discoveredClues.push(clueKey);
    localStorage.setItem('arg_progress', JSON.stringify(progress));
  }

  // 相关搜索推荐（模拟真实搜索引擎的相关搜索功能）
  // 在所有匹配的推荐词中查找与当前搜索词最匹配的条目
  var suggestionKey = '';
  var lowerQueryForSuggest = query.toLowerCase();
  var suggestKeys = Object.keys(SEARCH_SUGGESTIONS);
  for (var sk = 0; sk < suggestKeys.length; sk++) {
    if (lowerQueryForSuggest.includes(suggestKeys[sk].toLowerCase())) {
      suggestionKey = suggestKeys[sk];
      break;
    }
  }

  if (suggestionKey) {
    var urlParams = new URLSearchParams(window.location.search);
    var showHint = urlParams.get('hint') === '1';
    var suggestions = SEARCH_SUGGESTIONS[suggestionKey];
    // 卡关时优先使用 stuck 推荐，否则使用 normal 推荐
    var words = showHint && suggestions.stuck.length > 0 ? suggestions.stuck : suggestions.normal;

    if (words.length > 0) {
      html += `<div class="card" style="margin-top:16px;padding:12px 16px;background:var(--color-bg-secondary);">
        <p style="font-size:0.78rem;color:var(--color-text-muted);margin-bottom:8px;">相关搜索</p>
        <p style="font-size:0.82rem;margin:0;line-height:2;">
          ${words
            .map(function (w) {
              return `<a href="${BASE}search/?q=${encodeURIComponent(w)}">${w}</a>`;
            })
            .join(' &nbsp;·&nbsp; ')}
        </p>
      </div>`;
    }
  }
</script>
