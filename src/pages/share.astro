    <script is:inline>
      (function () {
        // 检查是否已通过搜索触发解锁
        var progress = JSON.parse(localStorage.getItem('arg_progress') || '{}');
        var isUnlocked = !!(progress.solvedPuzzles && progress.solvedPuzzles['stage1_page_header_password']);
        var lockPrompt = document.getElementById('lock-prompt');
        var lockInput = document.getElementById('lock-input');
        var lockSubmit = document.getElementById('lock-submit');
        var lockError = document.getElementById('lock-error');

        function unlock() {
          if (lockPrompt) lockPrompt.style.display = 'none';
          isUnlocked = true;
          // 记录解锁状态
          if (!progress.solvedPuzzles) progress.solvedPuzzles = {};
          progress.solvedPuzzles['stage1_page_header_password'] = true;
          if (!progress.discoveredClues) progress.discoveredClues = [];
          if (!progress.discoveredClues.includes('cloud_share_accessed')) {
            progress.discoveredClues.push('cloud_share_accessed');
            progress.explorationProgress = (progress.explorationProgress || 0) + 15;
          }
          localStorage.setItem('arg_progress', JSON.stringify(progress));
        }

        function tryUnlock(code) {
          if (code.trim() === '多站同源2026') {
            unlock();
          } else if (lockError) {
            lockError.style.display = 'block';
          }
        }

        // 初始状态
        if (isUnlocked) {
          if (lockPrompt) lockPrompt.style.display = 'none';
        } else {
          if (lockPrompt) lockPrompt.style.display = 'block';
        }

        // 解锁按钮
        if (lockSubmit && lockInput) {
          lockSubmit.addEventListener('click', function () {
            tryUnlock(lockInput.value);
          });
          lockInput.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') tryUnlock(lockInput.value);
          });
        }

        // 文件点击：如果未解锁，提示需要密码
        var items = document.querySelectorAll('.file-item');
        items.forEach(function (item) {
          item.addEventListener('click', function () {
            if (!isUnlocked) {
              if (lockPrompt) {
                lockPrompt.style.display = 'block';
                lockPrompt.style.background = '#fff2f0';
                lockPrompt.style.borderColor = '#ffccc7';
                setTimeout(function () {
                  if (lockPrompt) {
                    lockPrompt.style.background = '#fffbe6';
                    lockPrompt.style.borderColor = '#f0e0a0';
                  }
                }, 1500);
              }
              return;
            }

            var fileId = this.dataset.file;
            var preview = document.getElementById('preview-' + fileId);
            if (!preview) return;
            var isOpen = preview.style.display === 'block';
            document.querySelectorAll('.file-preview').forEach(function (p) {
              p.style.display = 'none';
            });
            document.querySelectorAll('.file-arrow').forEach(function (a) {
              a.textContent = '▸';
            });
            if (!isOpen) {
              preview.style.display = 'block';
              this.querySelector('.file-arrow').textContent = '▾';
            }
          });
        });
      })();
    </script>
