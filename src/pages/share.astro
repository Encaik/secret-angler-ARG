    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <title>加密共享 — 轻舟云盘</title>
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        background: #f0f2f5;
        color: #333;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .container {
        max-width: 680px;
        width: 92%;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 20px rgba(0, 0, 0, 0.08);
        overflow: hidden;
      }
      .header {
        background: linear-gradient(135deg, #1677ff, #0958d9);
        color: #fff;
        padding: 28px 32px;
      }
      .header .brand {
        font-size: 0.8rem;
        opacity: 0.8;
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        gap: 6px;
      }
      .header .brand svg {
        width: 18px;
        height: 18px;
        opacity: 0.8;
      }
      .header h1 {
        font-size: 1.2rem;
        font-weight: 500;
        margin-bottom: 4px;
      }
      .header .meta {
        font-size: 0.78rem;
        opacity: 0.7;
      }
      .header .meta span {
        margin-right: 16px;
      }

      .body {
        padding: 0;
      }

      /* 文件行 */
      .file-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 32px;
        border-bottom: 1px solid #f0f0f0;
        cursor: pointer;
        transition: background 0.15s;
      }
      .file-item:hover {
        background: #fafbfc;
      }
      .file-item:last-of-type {
        border-bottom: none;
      }
      .file-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        flex-shrink: 0;
      }
      .file-icon.csv {
        background: #e6f7e6;
      }
      .file-icon.txt {
        background: #f5f5f5;
      }
      .file-icon.md {
        background: #e6f4ff;
      }
      .file-info {
        flex: 1;
        min-width: 0;
      }
      .file-info .name {
        font-size: 0.9rem;
        font-weight: 500;
        margin-bottom: 2px;
      }
      .file-info .detail {
        font-size: 0.72rem;
        color: #999;
      }
      .file-size {
        font-size: 0.78rem;
        color: #999;
        white-space: nowrap;
      }
      .file-arrow {
        color: #ccc;
        font-size: 0.8rem;
      }

      /* 文件预览展开 */
      .file-preview {
        display: none;
        padding: 20px 32px 24px;
        background: #fafbfc;
        border-bottom: 1px solid #f0f0f0;
        font-size: 0.84rem;
        line-height: 1.8;
      }
      .file-preview .preview-title {
        font-weight: 600;
        font-size: 0.9rem;
        margin-bottom: 8px;
        color: #333;
      }
      .file-preview .preview-meta {
        font-size: 0.72rem;
        color: #999;
        margin-bottom: 12px;
      }
      .file-preview hr {
        border: none;
        border-top: 1px solid #e8e8e8;
        margin-bottom: 12px;
      }
      .file-preview table {
        font-size: 0.76rem;
        border-collapse: collapse;
        width: 100%;
      }
      .file-preview th {
        text-align: left;
        padding: 4px 8px;
        border-bottom: 1px solid #e0e0e0;
        color: #666;
      }
      .file-preview td {
