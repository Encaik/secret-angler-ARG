---
// /user/center — 个人中心（登录后可见）
// 论坛标准用户面板：个人资料 + 我的帖文 + 私信入口
import Layout from '../../components/Layout.astro';
const BASE = __BASE_PATH__;
---

<Layout title="个人中心">
  <div class="breadcrumb">
    <a href={`${BASE}home/`} target="_blank">首页</a><span>›</span>
    个人中心
  </div>

  <!-- 未登录 -->
  <div id="not-logged-in" class="card" style="text-align: center; padding: 40px; max-width: 500px; margin: 40px auto;">
    <h2>👤 个人中心</h2>
    <hr />
    <p class="text-muted">请先<a href={`${BASE}login/`} target="_blank">登录</a>后再访问个人中心。</p>
  </div>

  <!-- 已登录 -->
  <div id="center-content" style="display: none;">
    <!-- 用户信息头 -->
    <div class="card" style="margin-bottom: 20px; display: flex; gap: 16px; align-items: center;">
      <div id="user-avatar" style="width: 56px; height: 56px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 1.4rem; flex-shrink: 0;"></div>
      <div style="flex: 1;">
        <h2 style="margin: 0 0 4px 0;" id="center-name"></h2>
        <p class="text-muted" style="margin: 0;">
          账号 <strong id="center-id"></strong> · 注册于 <span id="center-joined"></span>
        </p>
      </div>
      <div>
        <a href={`${BASE}inbox/`} target="_blank" style="display: inline-block; padding: 6px 16px; background: var(--color-bg-dark); color: #e0dcd5; text-decoration: none; border-radius: var(--radius-sm); font-size: 0.85rem;">
          📬 私信箱
        </a>
      </div>
    </div>

    <div class="two-col">
      <!-- 左栏：我发布的帖文 -->
      <div>
        <h3>📝 最近的帖文</h3>
        <div id="my-posts"><p class="text-muted">加载中……</p></div>
      </div>

      <!-- 右栏：账号管理 -->
      <div>
        <h3>⚙️ 账号管理</h3>
        <div class="card" style="padding: 12px; margin-bottom: 8px;">
          <p style="font-size: 0.85rem; margin: 0;"><strong>登录密码</strong></p>
          <p class="text-muted" style="font-size: 0.8rem; margin: 2px 0 8px;">已设置 · ********</p>
        </div>
        <button id="logout-btn" style="margin-top: 8px; color: #c0392b; border-color: #c0392b; background: transparent; padding: 6px 16px; cursor: pointer; width: 100%;">
          退出登录
        </button>
      </div>
    </div>
  </div>
</Layout>

<script>
  const loggedIn = localStorage.getItem('arg_logged_in') === 'true';
  const username = localStorage.getItem('arg_username');
  const progress = JSON.parse(localStorage.getItem('arg_progress') || '{}');
  const isMember = !!(progress.solvedPuzzles && progress.solvedPuzzles['stage1_page_header_password']);

  if (!loggedIn || !username) { document.getElementById('not-logged-in')!.style.display = 'block'; }
  else {
    document.getElementById('not-logged-in')!.style.display = 'none';
    document.getElementById('center-content')!.style.display = 'block';

    const users: Record<string, { name: string; joined: string; avatar: string; color: string; posts: {title: string; href: string; date: string; section: string}[] }> = {
      lyu: {
        name: 'signal_屿', joined: '2025-04-15', avatar: '🌌', color: '#2e6b8f',
        posts: [
          { title: '凤凰山信号异常——有人一起去实地考察吗？', href: '/community/post/246/', date: '2026-04-10', section: '外星目击' },
          { title: '凤凰山1420MHz异常信号全频段分析', href: '/alien/alien-001/', date: '2026-04-18', section: '外星目击' },
          { title: '全国外星目击高发区坐标数据集（47点）', href: '/alien/alien-002/', date: '2026-04-12', section: '外星目击' },
          { title: 'SDR入门：200块就能开始扫深空信号', href: '#', date: '2026-03-28', section: '外星目击' },
          { title: 'WOW信号再分析：1977年我们可能错过了什么', href: '#', date: '2026-03-05', section: '外星目击' },
        ]
      },
      shenci: {
        name: '地下三尺', joined: '2025-10-20', avatar: '🏛️', color: '#8b6914',
        posts: [
          { title: '明天去贺兰山，简单记录一下准备情况', href: '/community/post/247/', date: '2026-05-25', section: '古迹秘境' },
          { title: '下周贺兰山岩画探秘——有没有一起的？', href: '/community/post/241/', date: '2026-03-30', section: '古迹秘境' },
          { title: '贺兰山未记录岩画群手绘记录与初步分析', href: '/ruins/ruins-001/', date: '2026-05-02', section: '古迹秘境' },
          { title: '全国冷门古迹实地考察坐标合集', href: '/ruins/ruins-002/', date: '2026-04-22', section: '古迹秘境' },
          { title: '独行探秘安全手册：一个人的野外生存指南', href: '#', date: '2026-03-02', section: '古迹秘境' },
        ]
      }
    };

    const u = users[username] || { name: username, joined: '—', avatar: '👤', color: '#666', posts: [] };
    document.getElementById('center-name')!.textContent = u.name;
    document.getElementById('center-id')!.textContent = username;
    document.getElementById('center-joined')!.textContent = u.joined;
    const av = document.getElementById('user-avatar')!;
    av.style.background = u.color;
    av.textContent = u.avatar;

    // 帖文列表（仅近三个月）
    const recentPosts = u.posts.filter(p => p.date >= '2026-03');
    const postsHTML = recentPosts.length ? recentPosts.map(p =>
      `<div class="post-item">
        <div class="post-title"><a href="${p.href}" target="_blank">${p.title}</a></div>
        <div class="post-meta">${p.date} · <span class="tag tag-${p.section === '外星目击' ? 'alien' : 'ruins'}">${p.section}</span></div>
      </div>`
    ).join('') : '<p class="text-muted">暂无帖文</p>';
    document.getElementById('my-posts')!.innerHTML = postsHTML;

    document.getElementById('logout-btn')!.addEventListener('click', () => {
      localStorage.removeItem('arg_logged_in');
      localStorage.removeItem('arg_username');
      window.location.href = '/home/';
    });

    if (!progress.discoveredClues) progress.discoveredClues = [];
    if (!progress.discoveredClues.includes('center_visited')) {
      progress.discoveredClues.push('center_visited');
      progress.explorationProgress = (progress.explorationProgress || 0) + 2;
      localStorage.setItem('arg_progress', JSON.stringify(progress));
    }
  }
</script>
