---
// /user/center/ — 个人中心入口
// 不同登录用户跳转到各自的静态中心页，此页面仅作为未登录/未知用户的引导
import Layout from '../../../components/Layout.astro';
const BASE = __BASE_PATH__;
---

<Layout title="个人中心">
  <div class="breadcrumb">
    <a href={`${BASE}home/`} target="_blank">首页</a><span>›</span>
    个人中心
  </div>

  <div class="card" style="text-align: center; padding: 40px; max-width: 500px; margin: 40px auto;">
    <h2>👤 个人中心</h2>
    <hr />
    <p class="text-muted">请先<a href={`${BASE}login/`} target="_blank">登录</a>后再访问个人中心。</p>
  </div>
</Layout>

<script is:inline>
  // 已登录用户自动跳转到对应静态中心页，无需 JS 切换内容
  (function() {
    var loggedIn = localStorage.getItem('arg_logged_in');
    var username = localStorage.getItem('arg_username');
    if (loggedIn === 'true' && username) {
      var BASE = window.__BASE__ || '/';
      window.location.replace(BASE + 'user/center/' + username + '/');
    }
  })();
</script>
