---
// /user/center/shenci/ — 沈辞（地下三尺）个人中心 · 纯静态
import Layout from '../../../components/Layout.astro';
const BASE = __BASE_PATH__;
---

<Layout title="个人中心 — 地下三尺">
  <div class="breadcrumb">
    <a href={`${BASE}home/`} target="_blank">首页</a><span>›</span>
    个人中心
  </div>

  <!-- 用户信息头 -->
  <div class="card" style="margin-bottom: 20px; display: flex; gap: 16px; align-items: center;">
    <div style="width: 56px; height: 56px; border-radius: 50%; background: #8b6914; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 1.4rem; flex-shrink: 0;">🏛️</div>
    <div style="flex: 1;">
      <h2 style="margin: 0 0 4px 0;">地下三尺</h2>
      <p class="text-muted" style="margin: 0;">
        账号 <strong>shenci</strong> · 注册于 2025-10-20
      </p>
    </div>
    <div>
      <a href={`${BASE}inbox/`} target="_blank" style="display: inline-block; padding: 6px 16px; background: var(--color-bg-dark); color: #e0dcd5; text-decoration: none; border-radius: var(--radius-sm); font-size: 0.85rem;">
        📬 私信箱
      </a>
    </div>
  </div>

  <div class="two-col">
    <!-- 左栏：发布的帖文 -->
    <div>
      <h3>📝 最近的帖文</h3>

      <div class="post-item" style="border-left: 3px solid var(--color-accent);">
        <div class="post-title"><a href={`${BASE}community/post/247/`} target="_blank">明天去贺兰山，简单记录一下准备情况</a></div>
        <div class="post-meta">2026-05-25 · <span class="tag tag-ruins">古迹秘境</span></div>
      </div>
      <div class="post-item">
        <div class="post-title"><a href={`${BASE}community/post/241/`} target="_blank">下周贺兰山岩画探秘——有没有一起的？</a></div>
        <div class="post-meta">2026-03-30 · <span class="tag tag-ruins">古迹秘境</span></div>
      </div>
      <div class="post-item">
        <div class="post-title"><a href={`${BASE}ruins/ruins-001/`} target="_blank">贺兰山未记录岩画群手绘记录与初步分析</a></div>
        <div class="post-meta">2026-05-02 · <span class="tag tag-ruins">古迹秘境</span></div>
      </div>
      <div class="post-item">
        <div class="post-title"><a href={`${BASE}ruins/ruins-002/`} target="_blank">全国冷门古迹实地考察坐标合集（23处）</a></div>
        <div class="post-meta">2026-04-22 · <span class="tag tag-ruins">古迹秘境</span></div>
      </div>
      <div class="post-item">
        <div class="post-title"><a href="#" target="_blank">独行探秘安全手册：一个人的野外生存指南</a></div>
        <div class="post-meta">2026-03-02 · <span class="tag tag-ruins">古迹秘境</span></div>
      </div>

      <a href={`${BASE}user/shenci/`} target="_blank" style="font-size: 0.85rem;">查看全部帖文和动态 →</a>
    </div>

    <!-- 右栏：账号管理 -->
    <div>
      <h3>⚙️ 账号管理</h3>
      <div class="card" style="padding: 12px; margin-bottom: 8px;">
        <p style="font-size: 0.85rem; margin: 0;"><strong>登录密码</strong></p>
        <p class="text-muted" style="font-size: 0.8rem; margin: 2px 0 8px;">已设置 · ********</p>
      </div>
      <button id="logout-btn" style="margin-top: 8px; color: #c0392b; border-color: #c0392b; background: transparent; padding: 6px 16px; cursor: pointer; width: 100%;">
        退出登录
      </button>
    </div>
  </div>
</Layout>

<script is:inline>
  document.getElementById('logout-btn').addEventListener('click', function() {
    localStorage.removeItem('arg_logged_in');
    localStorage.removeItem('arg_username');
    var BASE = window.__BASE__ || '/';
    window.location.href = BASE + 'login/';
  });
</script>
