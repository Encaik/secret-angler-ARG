---
// /user/deephunter — 深海猎手（潜伏线索：后期叛变成员）
import Layout from '../../components/Layout.astro';
const BASE = __BASE_PATH__;
---
<Layout title="深海猎手的个人主页">
  <div class="breadcrumb"><a href={`${BASE}home/`} target="_blank">首页</a><span>›</span><a href={`${BASE}community/`} target="_blank">探秘者社区</a><span>›</span>深海猎手</div>
  <div class="card" style="margin-bottom:20px;display:flex;gap:16px;align-items:flex-start;">
    <div style="width:56px;height:56px;border-radius:50%;background:#2c5f7c;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.4rem;flex-shrink:0;">🌊</div>
    <div style="flex:1;">
      <h2 style="margin-bottom:2px;">深海猎手</h2>
      <p class="text-muted" style="margin-bottom:6px;">账号：deephunter · 注册于 2024-11-30</p>
      <p style="font-size:0.9rem;">潜水员。对水下考古和沉船打捞感兴趣。偶尔也跑跑陆地遗址。不常发帖，主要潜水看看。</p>
      <span class="tag tag-deepsea">深海探秘</span> <span class="tag tag-ruins">水下考古</span>
    </div>
  </div>
  <h3>📝 最近动态</h3>
  <div class="card" style="padding:10px;margin-bottom:8px;"><p style="font-size:0.85rem;color:#888;">该用户近期未发布任何动态。</p></div>
  <p class="text-muted" style="font-size:0.78rem;">最后登录：2026-03-30</p>
</Layout>
