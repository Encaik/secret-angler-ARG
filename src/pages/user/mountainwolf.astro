---
import Layout from '../../components/Layout.astro';
---
<Layout title="山野探秘人的个人主页">
  <div class="breadcrumb"><a href="/home/" target="_blank">首页</a><span>›</span>山野探秘人</div>
  <div class="card" style="margin-bottom:20px;display:flex;gap:16px;align-items:flex-start;">
    <div style="width:72px;height:72px;background:#4a6741;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.8rem;flex-shrink:0;">⛰️</div>
    <div style="flex:1;">
      <h2 style="margin-bottom:2px;">山野探秘人</h2>
      <p class="text-muted" style="margin-bottom:6px;">注册于 2025-03-08 · 探秘爱好者</p>
      <p style="font-size:0.9rem;margin-bottom:8px;">走过二十三个省。最美的风景永远不在攻略上。</p>
      <span class="tag tag-nature">探秘者</span>
    </div>
  </div>
  <p class="text-muted">该用户尚未发布公开帖文。</p>
</Layout>
