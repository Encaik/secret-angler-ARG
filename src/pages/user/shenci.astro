            <td><code>38.78, 106.03</code></td>
            <td><span class="tag tag-ruins">古迹</span></td>
          </tr>
          <tr style="background: #fdf5e6;">
            <td><a href={`${BASE}ruins/ruins-003/`} target="_blank">神农架远古石阵</a> ⚠</td>
