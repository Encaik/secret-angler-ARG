---
import Layout from '../../components/Layout.astro';
const BASE = __BASE_PATH__;
---

<Layout title="星海漫步的个人主页">
  <div class="breadcrumb"><a href={`${BASE}home/`} target="_blank">首页</a><span>›</span>星海漫步</div>
  <div class="card" style="margin-bottom:20px;display:flex;gap:16px;align-items:flex-start;">
    <div
      style="width:72px;height:72px;background:#2e6b8f;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.8rem;flex-shrink:0;"
    >
      🔭
    </div>
    <div style="flex:1;">
      <h2 style="margin-bottom:2px;">星海漫步</h2>
      <p class="text-muted" style="margin-bottom:6px;">注册于 2025-07-15 · 探秘爱好者</p>
      <p style="font-size:0.9rem;margin-bottom:8px;">望远镜+赤道仪。深空摄影入门中。</p>
      <span class="tag tag-alien">探秘者</span>
    </div>
  </div>
  <p class="text-muted">该用户尚未发布公开帖文。</p>
</Layout>
